# Šablona pro app/.env.local (necommitovaný soubor s reálnými hodnotami).
# Zkopíruj řádky do app/.env.local a vyplň.
#
# Do env patří jen to, co musí být k dispozici dřív než databáze. Veškerá provozní
# konfigurace (dodavatel na faktuře, číselná řada, záloha, přístupy k IMAP / MotoPressu
# / SMTP, název a adresa instance) se nastavuje v aplikaci a ukládá do databáze —
# do env už nic z toho nepatří.

# Náhodné tajemství frameworku (CSRF, podpisy). Vygeneruj: openssl rand -hex 32
APP_SECRET=vygeneruj-nahodny-32-znaky-hex

# Master klíč pro šifrování přístupových údajů uložených v databázi (credential store).
# Base64 z 32 náhodných bajtů. Bez něj nejde v UI ukládat hesla/klíče.
# Vygeneruj: php -r "echo base64_encode(random_bytes(32)).PHP_EOL;"
APP_CREDENTIALS_KEY=

# Připojení k databázi (server, účet, jméno DB). Uprav podle svého hostingu.
DATABASE_URL="mysql://user:heslo@127.0.0.1:3306/ubytovadlo?serverVersion=8.4&charset=utf8mb4"
