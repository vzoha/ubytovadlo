# Šablona pro app/.env.local (necommitovaný soubor s reálnými hodnotami).
# Zkopíruj relevantní řádky do app/.env.local a vyplň. .env (committed) drží jen
# neutrální defaulty — reálná tajemství a osobní/fakturační údaje patří SEM, ne tam.

# --- Tajemství ---
APP_SECRET=vygeneruj-nahodny-32-znaky-hex
IMAP_PASSWORD=heslo-emailove-schranky
IMAP_USERNAME=automatizace@tvojedomena.cz
MOTOPRESS_BASE_URL=https://tvuj-wordpress.cz
MOTOPRESS_CONSUMER_KEY=ck_...
MOTOPRESS_CONSUMER_SECRET=cs_...

# --- Konfigurace objektu ---
# Nazev Airbnb inzeratu tak, jak se objevuje v potvrzovacich e-mailech (kotvi
# extrakci regionu hosta). Prazdne = region se necte.
AIRBNB_LISTING_NAME="Vejminek"

# --- Obecné (volitelné — přednostně se nastavuje v UI /nastaveni/obecne) ---
# Slouží jen jako fallback pro čerstvou instanci; po vyplnění v UI má přednost DB.
APP_BRAND_NAME="Ubytovadlo"
# Veřejná adresa aplikace pro odkazy v e-mailech odeslaných z cronu.
DEFAULT_URI="https://app.tvojedomena.cz"

# --- Fakturační profil vystavovatele (PII — NIKDY do .env) ---
# Přednostně se vyplňuje v UI /nastaveni/dodavatel; tohle je jen fallback.
# Pozor: DIC bývá rodné číslo, telefon a bankovní účet jsou osobní údaje.
INVOICE_ISSUER_NAME=""
INVOICE_ISSUER_STREET=""
INVOICE_ISSUER_CITY=""
INVOICE_ISSUER_ZIP=""
INVOICE_ISSUER_COUNTRY=""
INVOICE_ISSUER_ICO=""
INVOICE_ISSUER_DIC=""
INVOICE_ISSUER_PHONE=""
INVOICE_ISSUER_EMAIL=""
INVOICE_ISSUER_WEB=""
INVOICE_BANK_ACCOUNT=""
INVOICE_BANK_IBAN=""

# Navázání číselné řady faktur (rok → první pořadové číslo). Přednostně v UI
# /nastaveni/fakturace; tohle je jen fallback. Prázdná mapa = každý rok od 1.
INVOICE_SERIES_STARTS='{}'
