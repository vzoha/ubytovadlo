# Šablona pro app/.env.local (necommitovaný soubor s reálnými hodnotami).
# Zkopíruj relevantní řádky do app/.env.local a vyplň. .env (committed) drží jen
# neutrální defaulty — reálná tajemství a osobní/fakturační údaje patří SEM, ne tam.

# --- Tajemství ---
APP_SECRET=vygeneruj-nahodny-32-znaky-hex
IMAP_PASSWORD=heslo-emailove-schranky
IMAP_USERNAME=automatizace@tvojedomena.cz
MOTOPRESS_BASE_URL=https://tvuj-wordpress.cz
MOTOPRESS_CONSUMER_KEY=ck_...
MOTOPRESS_CONSUMER_SECRET=cs_...

# --- Konfigurace objektu ---
# Nazev Airbnb inzeratu tak, jak se objevuje v potvrzovacich e-mailech (kotvi
# extrakci regionu hosta). Prazdne = region se necte.
AIRBNB_LISTING_NAME="Vejminek"

# --- Fakturační profil vystavovatele (PII — NIKDY do .env) ---
# Pozor: DIC bývá rodné číslo, telefon a bankovní účet jsou osobní údaje.
INVOICE_ISSUER_NAME="Jméno Příjmení"
INVOICE_ISSUER_STREET="Ulice 1"
INVOICE_ISSUER_CITY="Město"
INVOICE_ISSUER_ZIP="00000"
INVOICE_ISSUER_COUNTRY="Česká republika"
INVOICE_ISSUER_ICO="00000000"
INVOICE_ISSUER_DIC="CZ0000000000"
INVOICE_ISSUER_PHONE="+420 000 000 000"
INVOICE_ISSUER_EMAIL="info@example.com"
INVOICE_ISSUER_WEB="https://example.com"
INVOICE_BANK_ACCOUNT="000000000/0000"
INVOICE_BANK_IBAN="CZ0000000000000000000000"
