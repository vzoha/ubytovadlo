{
    "name": "ubytovadlo/app",
    "type": "project",
    "license": "LicenseRef-FSL-1.1-ALv2",
    "description": "Ubytovadlo — automatizace rezervací, fakturace a evidence pro malé ubytování",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/doctrine-bundle": "^3.2.4",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.6.7",
        "giggsey/libphonenumber-for-php-lite": "^9.0",
        "granam/czech-vocative": "^2.2",
        "league/commonmark": "^2.8",
        "mpdf/mpdf": "^8.3.1",
        "mpdf/qrcode": "^1.2.2",
        "smalot/pdfparser": "^2.12.5",
        "symfony/asset": "7.4.*",
        "symfony/console": "7.4.*",
        "symfony/dotenv": "7.4.*",
        "symfony/flex": "^2.11",
        "symfony/form": "7.4.*",
        "symfony/framework-bundle": "7.4.*",
        "symfony/http-client": "7.4.*",
        "symfony/intl": "7.4.*",
        "symfony/mailer": "7.4.*",
        "symfony/maker-bundle": "^1.67",
        "symfony/mime": "7.4.*",
        "symfony/monolog-bundle": "^4.0.2",
        "symfony/runtime": "7.4.*",
        "symfony/security-bundle": "7.4.*",
        "symfony/twig-bundle": "7.4.*",
        "symfony/validator": "7.4.*",
        "symfony/yaml": "7.4.*",
        "twig/extra-bundle": "^3.24",
        "webklex/php-imap": "^6.2",
        "zbateson/mail-mime-parser": "^4.0.1"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "deploy-www": "@php deploy/shared-host/sync-www.php",
        "cs": "php-cs-fixer fix",
        "cs:check": "php-cs-fixer fix --dry-run --diff",
        "stan": "phpstan analyse --no-progress",
        "test": "phpunit",
        "check": [
            "@cs:check",
            "@stan",
            "@test"
        ]
    },
    "scripts-descriptions": {
        "cs": "Srovná code style (php-cs-fixer fix)",
        "cs:check": "Zkontroluje code style bez zápisu",
        "stan": "Statická analýza (PHPStan)",
        "test": "Spustí PHPUnit",
        "check": "Vše mechanické před commitem/pushem: cs:check + stan + test"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.4.*"
        }
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95.5",
        "phpstan/phpstan": "^2.2.2",
        "phpstan/phpstan-doctrine": "^2.0.27",
        "phpstan/phpstan-phpunit": "^2.0.16",
        "phpstan/phpstan-symfony": "^2.0.19",
        "phpunit/phpunit": "^13.2",
        "symfony/browser-kit": "7.4.*",
        "symfony/css-selector": "7.4.*"
    }
}
