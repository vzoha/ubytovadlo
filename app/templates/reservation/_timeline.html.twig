{# Časová osa rezervace: minulost (události + poznámky) → dnes → budoucí akce. #}
{% set now = date() %}
<div class="card mt-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Časová osa</span>
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="modal" data-bs-target="#modalNote">+ Poznámka</button>
            <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="modal" data-bs-target="#modalReminder">+ Připomínka</button>
        </div>
    </div>
    <div class="card-body">
        {% if timeline is empty %}
            <p class="text-muted small mb-0">Zatím žádné události.</p>
        {% else %}
            <ul class="list-unstyled mb-0 timeline">
                {% set divider_shown = false %}
                {% for item in timeline %}
                    {% if not divider_shown and item.at > now %}
                        <li class="d-flex align-items-center text-muted small my-2">
                            <hr class="flex-grow-1 my-0"><span class="px-2">dnes {{ now|date('d. m. Y') }}</span><hr class="flex-grow-1 my-0">
                        </li>
                        {% set divider_shown = true %}
                    {% endif %}
                    <li class="d-flex gap-2 py-2 border-bottom">
                        <div class="fs-5">{{ item.icon }}</div>
                        <div class="flex-grow-1">
                            <div class="d-flex justify-content-between">
                                <span class="fw-semibold">
                                    {{ item.title }}
                                    {% if item.kind == 'action' and item.status and item.status.value != 'planned' %}
                                        <span class="badge text-bg-{{ item.status.badge }}">{{ item.status.label }}</span>
                                    {% elseif item.isOpenAction and item.at < now %}
                                        <span class="badge text-bg-danger">po termínu</span>
                                    {% endif %}
                                </span>
                                <span class="text-muted small text-nowrap ms-2">{{ item.at|date(item.dateOnly ? 'd. m. Y' : 'd. m. Y H:i') }}</span>
                            </div>
                            {% if item.body %}<div class="small">{{ item.body|nl2br }}</div>{% endif %}
                            {% if item.meta %}<div class="text-muted small">{{ item.meta }}</div>{% endif %}

                            {% if item.isOpenAction %}
                                <div class="d-flex gap-1 mt-1 flex-wrap align-items-center">
                                    <form method="post" action="{{ path('reservation_action_done', {id: item.action.id}) }}" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('action-edit-' ~ item.action.id) }}">
                                        <button class="btn btn-outline-success btn-sm py-0">Hotovo</button>
                                    </form>
                                    <form method="post" action="{{ path('reservation_action_reschedule', {id: item.action.id}) }}" class="d-inline d-flex gap-1">
                                        <input type="hidden" name="_token" value="{{ csrf_token('action-edit-' ~ item.action.id) }}">
                                        <input type="datetime-local" name="scheduled_for" class="form-control form-control-sm py-0" value="{{ item.at|date('Y-m-d\\TH:i') }}" style="width:12rem">
                                        <button class="btn btn-outline-secondary btn-sm py-0">Odložit</button>
                                    </form>
                                    <form method="post" action="{{ path('reservation_action_cancel', {id: item.action.id}) }}" class="d-inline" onsubmit="return confirm('Zrušit tuto akci?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('action-edit-' ~ item.action.id) }}">
                                        <button class="btn btn-outline-danger btn-sm py-0">Zrušit</button>
                                    </form>
                                </div>
                            {% endif %}
                        </div>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </div>
</div>

<div class="modal fade" id="modalNote" tabindex="-1" aria-labelledby="modalNoteLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title h6 mb-0" id="modalNoteLabel">Nová poznámka</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Zavřít"></button>
            </div>
            <form method="post" action="{{ path('reservation_add_note', {id: reservation.id}) }}">
                <div class="modal-body">
                    <input type="hidden" name="_token" value="{{ csrf_token('note-' ~ reservation.id) }}">
                    <div class="mb-2">
                        <label class="form-label small mb-1">Typ</label>
                        <select name="type" class="form-select form-select-sm">
                            {% for t in note_types %}
                                <option value="{{ t.value }}">{{ t.icon }} {{ t.label }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small mb-1">Kdy</label>
                        <input type="datetime-local" name="occurred_at" class="form-control form-control-sm" value="{{ now|date('Y-m-d\\TH:i') }}">
                    </div>
                    <div class="mb-0">
                        <label class="form-label small mb-1">Text</label>
                        <input type="text" name="body" class="form-control form-control-sm" placeholder="Co se stalo…" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Zrušit</button>
                    <button class="btn btn-sm btn-primary">Uložit</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modalReminder" tabindex="-1" aria-labelledby="modalReminderLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title h6 mb-0" id="modalReminderLabel">Nová připomínka</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Zavřít"></button>
            </div>
            <form method="post" action="{{ path('reservation_add_action', {id: reservation.id}) }}">
                <div class="modal-body">
                    <input type="hidden" name="_token" value="{{ csrf_token('action-' ~ reservation.id) }}">
                    <div class="mb-2">
                        <label class="form-label small mb-1">Druh</label>
                        <select name="type" class="form-select form-select-sm">
                            <option value="custom_reminder">⏰ Připomínka</option>
                            <option value="custom_message">✉️ Zpráva hostovi</option>
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small mb-1">Termín</label>
                        <input type="datetime-local" name="scheduled_for" class="form-control form-control-sm" value="{{ now|date('Y-m-d\\TH:i') }}" required>
                    </div>
                    <div class="mb-0">
                        <label class="form-label small mb-1">Text</label>
                        <input type="text" name="text" class="form-control form-control-sm" placeholder="Na co nezapomenout…" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Zrušit</button>
                    <button class="btn btn-sm btn-primary">Naplánovat</button>
                </div>
            </form>
        </div>
    </div>
</div>
