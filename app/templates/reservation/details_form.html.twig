{% extends 'base.html.twig' %}

{% block title %}Doplnit údaje — rezervace #{{ reservation.id }}{% endblock %}

{% block body %}
    <h1 class="h3 mb-3">Doplnit údaje hosta</h1>
    <p class="text-muted">
        {{ reservation.channel.label }}
        {% if reservation.externalId %}· kód <code>{{ reservation.externalId }}</code>{% endif %}
        · příjezd {{ reservation.checkIn|date('d. m. Y') }}
    </p>

    {% if reservation.channel.value == 'booking' %}
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Načíst z Booking extranetu</span>
                <small class="text-muted">vlož celý detail rezervace ze stránky v admin.booking.com</small>
            </div>
            <div class="card-body">
                <form method="post" action="{{ path('reservation_import_booking', {id: reservation.id}) }}">
                    <div class="mb-2">
                        <textarea name="raw" rows="6" class="form-control font-monospace" placeholder="Sem zkopíruj text z extranetu (Ctrl+A → Ctrl+C v okně rezervace)…" required></textarea>
                    </div>
                    <input type="hidden" name="_token" value="{{ csrf_token('import-booking-' ~ reservation.id) }}">
                    <button type="submit" class="btn btn-outline-primary btn-sm">Naimportovat údaje</button>
                </form>
            </div>
        </div>
    {% endif %}

    {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}
    <div class="row g-3">
        <div class="col-md-6">{{ form_row(form.guestName) }}</div>
        <div class="col-md-6">{{ form_row(form.guestContact.email) }}</div>
        <div class="col-md-6">{{ form_row(form.guestContact.phone) }}</div>
        <div class="col-md-6">{{ form_row(form.guestAddress.street) }}</div>
        <div class="col-md-2">{{ form_row(form.guestAddress.zip) }}</div>
        <div class="col-md-3">{{ form_row(form.guestAddress.city) }}</div>
        <div class="col-md-1">{{ form_row(form.guestAddress.country) }}</div>
        <div class="col-md-12"><hr><h6 class="text-muted">Firemní údaje (pokud chce host fakturovat na firmu)</h6></div>
        <div class="col-md-6">{{ form_row(form.guestBilling.companyName) }}</div>
        <div class="col-md-3">{{ form_row(form.guestBilling.ico) }}</div>
        <div class="col-md-3">{{ form_row(form.guestBilling.dic) }}</div>
        <div class="col-md-12"><hr></div>
        <div class="col-md-3">{{ form_row(form.guestsAdult) }}</div>
        <div class="col-md-3">{{ form_row(form.guestsChild) }}</div>
        <div class="col-md-12"><hr></div>
        <div class="col-md-3 d-flex align-items-center">{{ form_row(form.hasPet) }}</div>
        <div class="col-md-9">{{ form_row(form.petsNote) }}</div>
        <div class="col-md-12 d-flex align-items-center">{{ form_row(form.needsBabyCot) }}</div>
        <div class="col-md-12">{{ form_row(form.notes) }}</div>
        <div class="col-md-12">{{ form_row(form.acquisitionSource) }}</div>
    </div>
    <datalist id="acquisition-sources">
        <option value="Booking">
        <option value="Airbnb">
        <option value="Web">
        <option value="Facebook">
        <option value="Návrat">
        <option value="E-chalupy">
        <option value="CS-chalupy">
        <option value="Kudyznudy">
        <option value="Doporučení">
        <option value="Neznámo">
    </datalist>
    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Uložit</button>
        <a href="{{ path('reservation_detail', {id: reservation.id}) }}" class="btn btn-outline-secondary">Zrušit</a>
    </div>
    {{ form_end(form) }}
{% endblock %}
