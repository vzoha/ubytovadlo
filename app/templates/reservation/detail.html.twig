{% extends 'base.html.twig' %}

{% block title %}Rezervace #{{ reservation.id }}{% endblock %}

{% block body %}
    <a href="{{ path('reservation_list') }}" class="text-decoration-none small">← Rezervace</a>
    <div class="d-flex justify-content-between align-items-start mb-3 gap-2 flex-wrap">
        <div>
            <h1 class="h3 mb-0 mt-1">{{ reservation.guestName ?? ('Rezervace #' ~ reservation.id) }}</h1>
            <div class="text-muted">
                {{ reservation.channel.label }}
                {% if reservation.externalId %}· kód <code>{{ reservation.externalId }}</code>{% endif %}
                {% if reservation.motopressExternalId %}· MotoPress #{{ reservation.motopressExternalId }}{% endif %}
            </div>
        </div>
        <div class="text-end">
            {% set badge = {
                needs_details: 'warning',
                confirmed: 'success',
                in_progress: 'primary',
                completed: 'secondary',
                cancelled: 'dark',
            }[reservation.status.value] %}
            <span class="badge text-bg-{{ badge }} fs-6">{{ reservation.status.label }}</span>
            {% if reservation.channel.value in ['web', 'direct'] and reservation.status.value not in ['cancelled', 'completed'] %}
                {% set already_confirmed = reservation.status.value != 'needs_details' %}
                <form method="post" action="{{ path('reservation_confirm', {id: reservation.id}) }}" class="mt-2"
                      onsubmit="return confirm('Potvrdit rezervaci a poslat hostovi potvrzovací e-mail?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('confirm-' ~ reservation.id) }}">
                    <button type="submit" class="btn btn-sm btn-outline-success">
                        {{ already_confirmed ? 'Poslat potvrzení znovu' : 'Potvrdit a poslat hostovi' }}
                    </button>
                </form>
            {% endif %}
        </div>
    </div>

    {% if reservation.status.value == 'needs_details' %}
        <div class="alert alert-warning d-flex align-items-center flex-wrap gap-2">
            <span class="me-3">
                Tato rezervace čeká na doplnění údajů hosta.
                {% if reservation.motopressExternalId and reservation.channel.value != 'web' %}
                    Vznikla z iCal bloku v MotoPressu — host data dohledej v {{ reservation.channel.label }} extranetu.
                {% endif %}
            </span>
            <a href="{{ path('reservation_details', {id: reservation.id}) }}" class="btn btn-warning btn-sm">Doplnit</a>
        </div>
    {% endif %}

    <div class="row g-3">
        {# Levý sloupec: kdo, kdy, peníze — nejčastěji sledované. #}
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header">Pobyt</div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-4">Příjezd</dt>
                        <dd class="col-8">{{ reservation.checkIn|date('d. m. Y') }} {% if reservation.checkInTime %}{{ reservation.checkInTime|date('H:i') }}{% endif %}</dd>

                        <dt class="col-4">Odjezd</dt>
                        <dd class="col-8">{{ reservation.checkOut ? reservation.checkOut|date('d. m. Y') : '—' }} {% if reservation.checkOutTime %}{{ reservation.checkOutTime|date('H:i') }}{% endif %}</dd>

                        <dt class="col-4">Nocí</dt>
                        <dd class="col-8">{% if reservation.checkOut %}{{ reservation.checkIn.diff(reservation.checkOut).days }}{% else %}<span class="text-muted">—</span>{% endif %}</dd>

                        <dt class="col-4">Hosté</dt>
                        <dd class="col-8">
                            {{ reservation.guestsAdult }} dospěl{{ reservation.guestsAdult == 1 ? 'ý' : 'í' }}
                            {% if reservation.guestsChild %}, {{ reservation.guestsChild }} dít{{ reservation.guestsChild == 1 ? 'ě' : 'ě' }}{% endif %}
                            {% if reservation.guestsInfant %}, {{ reservation.guestsInfant }} kojen{{ reservation.guestsInfant == 1 ? 'ec' : 'ci' }}{% endif %}
                        </dd>

                        <dt class="col-4">Objednáno</dt>
                        <dd class="col-8">
                            {% if reservation.bookedAt %}
                                {{ reservation.bookedAt|date('d. m. Y H:i') }}
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </dd>

                        <dt class="col-4">Vytvořeno u nás</dt>
                        <dd class="col-8 text-muted">{{ reservation.createdAt|date('d. m. Y H:i') }}</dd>
                    </dl>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header d-flex justify-content-between">
                    <span>Host</span>
                    <a href="{{ path('reservation_details', {id: reservation.id}) }}" class="btn btn-sm btn-link p-0">Upravit</a>
                </div>
                <div class="card-body">
                    {% set phone = reservation.guestPhone|phone %}
                    <dl class="row mb-0">
                        <dt class="col-5 col-sm-4">Jméno</dt>
                        <dd class="col-7 col-sm-8">{{ reservation.guestName ?? '—' }}</dd>

                        <dt class="col-5 col-sm-4">E-mail</dt>
                        <dd class="col-7 col-sm-8 text-break">
                            {% if reservation.guestEmail %}
                                <a href="mailto:{{ reservation.guestEmail }}">{{ reservation.guestEmail }}</a>
                            {% else %}—{% endif %}
                        </dd>

                        <dt class="col-5 col-sm-4">Telefon</dt>
                        <dd class="col-7 col-sm-8">{{ phone ? phone.national : (reservation.guestPhone ?? '—') }}</dd>

                        <dt class="col-5 col-sm-4">Adresa</dt>
                        <dd class="col-7 col-sm-8">{{ reservation.guestAddressFormatted ?? '—' }}</dd>

                        {% if reservation.guestCompanyName %}
                            <dt class="col-5 col-sm-4">Firma</dt>
                            <dd class="col-7 col-sm-8">{{ reservation.guestCompanyName }}</dd>

                            <dt class="col-5 col-sm-4">IČO / DIČ</dt>
                            <dd class="col-7 col-sm-8">{{ reservation.guestIco ?? '—' }} / {{ reservation.guestDic ?? '—' }}</dd>
                        {% endif %}

                        {% if reservation.guestRegion %}
                            <dt class="col-5 col-sm-4">Region</dt>
                            <dd class="col-7 col-sm-8">{{ reservation.guestRegion }}</dd>
                        {% endif %}

                        {% if reservation.hasPet %}
                            <dt class="col-5 col-sm-4">Pes</dt>
                            <dd class="col-7 col-sm-8"><span class="badge text-bg-warning">ano</span>{% if reservation.petsNote %} · {{ reservation.petsNote }}{% endif %}</dd>
                        {% endif %}

                        {% if reservation.needsBabyCot %}
                            <dt class="col-5 col-sm-4">Dětská postýlka</dt>
                            <dd class="col-7 col-sm-8"><span class="badge text-bg-info">připravit</span></dd>
                        {% endif %}
                    </dl>

                    {% if phone or reservation.guestEmail %}
                        <div class="d-flex gap-2 flex-wrap mt-3">
                            {% if phone %}
                                <a href="tel:{{ phone.e164 }}" class="btn btn-sm btn-outline-primary">📞 Volat</a>

                                <div class="btn-group">
                                    <a href="https://wa.me/{{ phone.whatsapp }}" target="_blank" rel="noopener" class="btn btn-sm btn-outline-success">WhatsApp</a>
                                    {% if quick_messages is not empty %}
                                        <button type="button" class="btn btn-sm btn-outline-success dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false"><span class="visually-hidden">Předvyplnit šablonou</span></button>
                                        <ul class="dropdown-menu">
                                            <li><h6 class="dropdown-header">Předvyplnit šablonou</h6></li>
                                            {% for m in quick_messages %}
                                                <li><a class="dropdown-item" href="https://wa.me/{{ phone.whatsapp }}?text={{ m.text|url_encode }}" target="_blank" rel="noopener">{{ m.label }}</a></li>
                                            {% endfor %}
                                        </ul>
                                    {% endif %}
                                </div>

                                <div class="btn-group">
                                    <a href="sms:{{ phone.e164 }}" class="btn btn-sm btn-outline-primary">💬 SMS</a>
                                    {% if quick_messages is not empty %}
                                        <button type="button" class="btn btn-sm btn-outline-primary dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false"><span class="visually-hidden">Předvyplnit šablonou</span></button>
                                        <ul class="dropdown-menu">
                                            <li><h6 class="dropdown-header">Předvyplnit šablonou</h6></li>
                                            {% for m in quick_messages %}
                                                <li><a class="dropdown-item" href="sms:{{ phone.e164 }}?body={{ m.text|url_encode }}">{{ m.label }}</a></li>
                                            {% endfor %}
                                        </ul>
                                    {% endif %}
                                </div>
                            {% endif %}
                            {% if reservation.guestEmail %}
                                <a href="mailto:{{ reservation.guestEmail }}" class="btn btn-sm btn-outline-primary">✉️ E-mail</a>
                            {% endif %}
                        </div>
                    {% endif %}
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Finance</span>
                    {% if balance %}<span class="badge text-bg-{{ balance.status.badge }}">{{ balance.status.label }}</span>{% endif %}
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-6">Celkem od hosta</dt>
                        <dd class="col-6 text-end">
                            {% if reservation.priceTotal %}{{ reservation.priceTotal|number_format(2, ',', ' ') }} {{ reservation.priceCurrency }}{% else %}—{% endif %}
                        </dd>

                        {% if balance %}
                            <dt class="col-6 text-muted">Zaplaceno</dt>
                            <dd class="col-6 text-end text-muted">{{ balance.paid|number_format(0, ',', ' ') }} Kč</dd>

                            <dt class="col-6 fw-bold">Zbývá doplatit</dt>
                            <dd class="col-6 text-end fw-bold {{ balance.settled ? 'text-success' : 'text-danger' }}">
                                {% if balance.settled %}
                                    0 Kč <span class="badge text-bg-success">uhrazeno</span>
                                {% else %}
                                    {{ balance.remaining|number_format(0, ',', ' ') }} Kč
                                {% endif %}
                            </dd>
                        {% endif %}

                        <dt class="col-6">Provize OTA</dt>
                        <dd class="col-6 text-end">
                            {% if reservation.commissionAmount %}{{ reservation.commissionAmount|number_format(2, ',', ' ') }} {{ reservation.commissionCurrency }}{% else %}—{% endif %}
                        </dd>

                        <dt class="col-6">Čistá výplata</dt>
                        <dd class="col-6 text-end fw-bold">
                            {% if reservation.netPayout %}{{ reservation.netPayout|number_format(2, ',', ' ') }} {{ reservation.priceCurrency }}{% else %}—{% endif %}
                        </dd>

                        <dt class="col-6">Přijaté platby</dt>
                        <dd class="col-6 text-end">
                            {% if receipts is empty %}<span class="text-muted">—</span>{% endif %}
                        </dd>
                    </dl>
                    {% if receipts is not empty %}
                        <ul class="list-unstyled small mb-0">
                            {% for r in receipts %}
                                <li class="d-flex justify-content-between align-items-center border-top py-1">
                                    <span>
                                        {{ r.receivedOn ? r.receivedOn|date('j. n. Y') : 'neznámé datum' }}
                                        <span class="badge text-bg-{{ r.source.realized ? 'success' : 'secondary' }}">{{ r.source.label }}</span>
                                    </span>
                                    <span class="d-flex align-items-center gap-2">
                                        <span class="fw-semibold">{{ r.amountCzk|number_format(0, ',', ' ') }} Kč</span>
                                        {% if r.originType.value == 'manual_payment' %}
                                            <form method="post" action="{{ path('reservation_delete_payment', {id: r.id}) }}" onsubmit="return confirm('Smazat platbu?')">
                                                <input type="hidden" name="_token" value="{{ csrf_token('payment-delete-' ~ r.id) }}">
                                                <button class="btn btn-sm btn-link text-danger p-0" title="Smazat platbu">×</button>
                                            </form>
                                        {% endif %}
                                    </span>
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}

                    {% if reservation.channel.value in ['airbnb', 'booking'] %}
                        <form method="post" action="{{ path('reservation_record_payout', {id: reservation.id}) }}" class="row g-2 align-items-end mt-2 border-top pt-2">
                            <input type="hidden" name="_token" value="{{ csrf_token('payout-' ~ reservation.id) }}">
                            <div class="col-7 col-sm-5">
                                <label class="form-label small mb-0">Reálná výplata (Kč)</label>
                                <input name="amount" type="number" step="1" class="form-control form-control-sm" required>
                            </div>
                            <div class="col-5 col-sm-4">
                                <label class="form-label small mb-0">Datum</label>
                                <input name="received_on" type="date" class="form-control form-control-sm">
                            </div>
                            <div class="col-12 col-sm-3">
                                <button class="btn btn-sm btn-outline-primary w-100">Zapsat</button>
                            </div>
                        </form>
                    {% else %}
                        <form method="post" action="{{ path('reservation_record_payment', {id: reservation.id}) }}" class="row g-2 align-items-end mt-2 border-top pt-2">
                            <input type="hidden" name="_token" value="{{ csrf_token('payment-' ~ reservation.id) }}">
                            <div class="col-12"><label class="form-label small mb-0 text-muted">Zaznamenat platbu hosta (hotovost, převod, záloha bez faktury)</label></div>
                            <div class="col-7 col-sm-5">
                                <input name="amount" type="number" step="1" min="1" class="form-control form-control-sm" placeholder="Kč" required>
                            </div>
                            <div class="col-5 col-sm-4">
                                <input name="received_on" type="date" class="form-control form-control-sm">
                            </div>
                            <div class="col-12 col-sm-3">
                                <button class="btn btn-sm btn-outline-primary w-100">Zapsat</button>
                            </div>
                        </form>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Pravý sloupec: check-in, ekonomika a provozní evidence po pobytu. #}
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Online check-in</span>
                    {% if reservation.checkinCompletedAt %}
                        <span class="badge text-bg-success">dokončen {{ reservation.checkinCompletedAt|date('d. m. Y H:i') }}</span>
                    {% else %}
                        <span class="badge text-bg-warning">čeká na vyplnění</span>
                    {% endif %}
                </div>
                <div class="card-body">
                    {% set checkin_url = url('checkin_index', {token: reservation.checkinToken}) %}
                    <div class="input-group input-group-sm mb-2">
                        <input type="text" class="form-control" value="{{ checkin_url }}" readonly id="checkin-link">
                        <button class="btn btn-outline-secondary" type="button" data-copy="#checkin-link">Zkopírovat</button>
                    </div>

                    {% if guest_documents is not empty %}
                        <div class="table-responsive">
                            <table class="table table-sm small mb-2">
                                <thead class="text-muted"><tr><th>Jméno</th><th>Občanství</th><th>Doklad</th><th>Stav</th></tr></thead>
                                <tbody>
                                {% for g in guest_documents %}
                                    <tr>
                                        <td>{{ g.lastName }} {{ g.firstName }}</td>
                                        <td>{% if g.isCzechCitizen %}ČR{% elseif g.nationalityCode %}{{ g.nationalityCode }}{% else %}—{% endif %}</td>
                                        <td>{{ g.documentNumber ?? '—' }}</td>
                                        <td>{% if g.confirmedAt %}<span class="text-success">potvrzeno</span>{% else %}<span class="text-muted">rozpracováno</span>{% endif %}</td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <p class="text-muted small mb-2">Zatím žádný host nevyplnil check-in.</p>
                    {% endif %}

                    <div class="d-flex gap-2 flex-wrap">
                        <a href="{{ checkin_url }}" target="_blank" class="btn btn-sm btn-outline-primary">Otevřít jako host</a>
                        {% if reservation.checkinCompletedAt %}
                            <form method="post" action="{{ path('reservation_reset_checkin', {id: reservation.id}) }}" onsubmit="return confirm('Opravdu znovu otevřít check-in?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('reset-checkin-' ~ reservation.id) }}">
                                <button class="btn btn-sm btn-outline-warning">Znovu otevřít</button>
                            </form>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header d-flex justify-content-between align-items-center gap-2 flex-wrap">
                    <span>Ekonomika</span>
                    <span>
                        {% if (reservation.checkOut ?? reservation.checkIn) > date('today') %}
                            <span class="badge text-bg-warning">výhled — pobyt neproběhl</span>
                        {% endif %}
                        {% if profit.incomeIsEstimate %}
                            <span class="badge text-bg-warning">příjem odhadem</span>
                        {% endif %}
                    </span>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-6">Příjem</dt>
                        <dd class="col-6 text-end">
                            {% if profit.incomeCzk is not null %}
                                {{ profit.incomeCzk|number_format(0, ',', ' ') }} Kč{% if profit.incomeIsEstimate %} *{% endif %}
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </dd>

                        <dt class="col-6 text-muted">Provize OTA</dt>
                        <dd class="col-6 text-end text-muted">−{{ profit.commissionCzk|number_format(0, ',', ' ') }} Kč</dd>

                        <dt class="col-6 text-muted">DPH z provize
                            {% if profit.vatDeductible %}<span class="badge text-bg-secondary" title="Reverse charge z provize je u plátce odpočet">odpočet</span>{% endif %}
                        </dt>
                        <dd class="col-6 text-end text-muted">
                            {% if profit.vatDeductible %}0 Kč{% else %}−{{ profit.vatCzk|number_format(0, ',', ' ') }} Kč{% endif %}
                        </dd>

                        <dt class="col-6 text-muted">Elektřina
                            {% if profit.missingElectricity %}<span class="badge text-bg-secondary">chybí odečet</span>{% endif %}
                        </dt>
                        <dd class="col-6 text-end text-muted">−{{ profit.electricityCzk|number_format(0, ',', ' ') }} Kč</dd>

                        <dt class="col-6 text-muted">Úklid
                            {% if profit.missingCleaning %}<span class="badge text-bg-secondary">nezadán</span>{% endif %}
                        </dt>
                        <dd class="col-6 text-end text-muted">−{{ profit.cleaningCzk|number_format(0, ',', ' ') }} Kč</dd>

                        <dt class="col-6 text-muted">Rekreační poplatek</dt>
                        <dd class="col-6 text-end text-muted">−{{ profit.recreationFeeCzk|number_format(0, ',', ' ') }} Kč</dd>

                        <dt class="col-6 border-top pt-1">Výdaje celkem</dt>
                        <dd class="col-6 text-end border-top pt-1">−{{ profit.expensesTotalCzk|number_format(0, ',', ' ') }} Kč</dd>

                        <dt class="col-6 fw-bold">Zisk</dt>
                        <dd class="col-6 text-end fw-bold {{ profit.profitCzk is not null and profit.profitCzk < 0 ? 'text-danger' : 'text-success' }}">
                            {% if profit.profitCzk is not null %}
                                {{ profit.profitCzk|number_format(0, ',', ' ') }} Kč
                            {% else %}
                                <span class="text-muted fw-normal">—</span>
                            {% endif %}
                        </dd>

                        {% if profit.profitPerNightCzk is not null %}
                            <dt class="col-6 text-muted">Zisk / noc</dt>
                            <dd class="col-6 text-end text-muted">{{ profit.profitPerNightCzk|number_format(0, ',', ' ') }} Kč</dd>
                        {% endif %}
                    </dl>
                    {% if profit.incomeIsEstimate %}
                        <p class="small text-muted mb-0 mt-2">* Orientační přepočet kurzem ČNB — faktura zatím nevystavena.</p>
                    {% endif %}
                </div>
            </div>

            {% if reservation.totalKwh is not null %}
                <div class="card mt-3">
                    <div class="card-header d-flex justify-content-between">
                        <span>Elektřina</span>
                        <span class="small text-muted">
                            {% if reservation.electricitySource.value == 'measured' %}
                                <span class="badge text-bg-success">odečteno</span>
                            {% else %}
                                <span class="badge text-bg-secondary">rozpočteno</span>
                            {% endif %}
                        </span>
                    </div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-5">Spotřeba VT</dt>
                            <dd class="col-7 text-end">{{ reservation.vtKwh ?? 0 }} kWh</dd>
                            <dt class="col-5">Spotřeba NT</dt>
                            <dd class="col-7 text-end">{{ reservation.ntKwh ?? 0 }} kWh</dd>
                            <dt class="col-5">Celkem</dt>
                            <dd class="col-7 text-end fw-bold">{{ reservation.totalKwh }} kWh</dd>
                            {% if reservation.checkOut %}
                                {% set nights = reservation.checkIn.diff(reservation.checkOut).days %}
                                {% if nights > 0 %}
                                    <dt class="col-5">Na noc</dt>
                                    <dd class="col-7 text-end">{{ (reservation.totalKwh / nights)|number_format(1, ',', ' ') }} kWh/noc</dd>
                                {% endif %}
                            {% endif %}
                            {% if electricity_cost %}
                                <dt class="col-5">Náklad (orientačně)</dt>
                                <dd class="col-7 text-end">
                                    {{ electricity_cost.totalCzk|number_format(0, ',', ' ') }} Kč
                                    <div class="small text-muted">
                                        VT {{ electricity_cost.vtRate|number_format(2, ',', ' ') }} / NT {{ electricity_cost.ntRate|number_format(2, ',', ' ') }} Kč/kWh
                                    </div>
                                </dd>
                            {% endif %}
                        </dl>
                        <p class="small text-muted mb-0 mt-2">Hostovi neúčtujeme — elektřina je v ceně pobytu.</p>
                    </div>
                </div>
            {% endif %}

            {% if cleaning %}
                <div class="card mt-3">
                    <div class="card-header d-flex justify-content-between">
                        <span>Úklid</span>
                        {% if cleaning.payoutCzk > 0 %}
                            {% if cleaning.paidAt %}
                                <span class="badge text-bg-success">vyplaceno {{ cleaning.paidAt|date('d. m. Y') }}</span>
                            {% else %}
                                <span class="badge text-bg-warning">čeká na vyplacení</span>
                            {% endif %}
                        {% else %}
                            <span class="badge text-bg-secondary">bez výplaty</span>
                        {% endif %}
                    </div>
                    <div class="card-body">
                        <form method="post" action="{{ path('reservation_set_cleaning', {id: reservation.id}) }}"
                              data-cleaning-defaults="{{ cleaning_defaults|json_encode|e('html_attr') }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('cleaning-' ~ reservation.id) }}">
                            <div class="row g-2 mb-2">
                                <div class="col-sm-6">
                                    <label class="form-label small mb-1">Typ</label>
                                    <select name="type" class="form-select form-select-sm" data-cleaning-type>
                                        {% for t in cleaning_types %}
                                            <option value="{{ t.value }}" {{ cleaning.type == t ? 'selected' : '' }}>{{ t|cleaning_label }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="col-6 col-sm-3">
                                    <label class="form-label small mb-1">Náklad Kč</label>
                                    <input type="number" name="cost_czk" min="0" class="form-control form-control-sm" value="{{ cleaning.costCzk }}" data-cleaning-cost>
                                </div>
                                <div class="col-6 col-sm-3">
                                    <label class="form-label small mb-1">Výplata Kč</label>
                                    <input type="number" name="payout_czk" min="0" class="form-control form-control-sm" value="{{ cleaning.payoutCzk }}" data-cleaning-payout>
                                </div>
                            </div>
                            <div class="row g-2 mb-2">
                                <div class="col-sm-6">
                                    <label class="form-label small mb-1">Vyplaceno dne</label>
                                    <input type="date" name="paid_at" class="form-control form-control-sm" value="{{ cleaning.paidAt ? cleaning.paidAt|date('Y-m-d') : '' }}" data-cleaning-paid-at>
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label small mb-1">Poznámka</label>
                                    <input type="text" name="note" class="form-control form-control-sm" value="{{ cleaning.note ?? '' }}">
                                </div>
                            </div>
                            <button class="btn btn-primary btn-sm">Uložit úklid</button>
                            <p class="small text-muted mb-0 mt-2">Náklad vstupuje do zisk/noc i u Barči (oportunita). Výplata = jen reálná hotovost.</p>
                        </form>
                    </div>
                </div>
            {% endif %}

            {% if reservation.notes %}
                <div class="card mt-3">
                    <div class="card-header">Poznámka</div>
                    <div class="card-body">{{ reservation.notes|nl2br }}</div>
                </div>
            {% endif %}

            {% if reservation.acquisitionSource %}
                <div class="card mt-3">
                    <div class="card-header">Odkud nás zná</div>
                    <div class="card-body">{{ reservation.acquisitionSource }}</div>
                </div>
            {% endif %}
        </div>
    </div>

    {% set invoices = invoices ?? [] %}
    {% set has_deposit = false %}
    {% set has_final = false %}
    {% set has_full = false %}
    {% for inv in invoices %}
        {% if inv.type.value == 'deposit' %}{% set has_deposit = true %}{% endif %}
        {% if inv.type.value == 'final' %}{% set has_final = true %}{% endif %}
        {% if inv.type.value == 'full' %}{% set has_full = true %}{% endif %}
    {% endfor %}

    <div class="card mt-3 invoice-card">
        <div class="card-header d-flex justify-content-between align-items-center gap-2 flex-wrap">
            <span>Fakturace</span>
            <span class="text-muted small">
                {{ reservation.billingMode ? reservation.billingMode.label : 'fakturační režim není nastaven' }}
                {% if reservation.motopressPaymentGateway %}· MotoPress gateway <code>{{ reservation.motopressPaymentGateway }}</code>{% endif %}
            </span>
        </div>
        <div class="card-body">
            <form method="post" action="{{ path('reservation_set_billing_mode', {id: reservation.id}) }}" class="mb-3">
                <input type="hidden" name="_token" value="{{ csrf_token('billing-mode-' ~ reservation.id) }}">
                <div class="input-group input-group-sm">
                    <label class="input-group-text" for="bm">Režim</label>
                    <select name="billing_mode" id="bm" class="form-select">
                        <option value="">— neurčeno —</option>
                        {% for mode in billing_modes %}
                            <option value="{{ mode.value }}" {{ reservation.billingMode == mode ? 'selected' : '' }}>{{ mode.label }}</option>
                        {% endfor %}
                    </select>
                    <button class="btn btn-outline-secondary">Uložit režim</button>
                </div>
            </form>

            {% if invoices is empty %}
                <p class="text-muted small mb-2">Žádné faktury zatím nebyly vystaveny.</p>
            {% else %}
                <table class="table table-sm align-middle mb-2 invoice-table">
                        <thead class="small text-muted">
                        <tr><th>Číslo</th><th>Typ</th><th class="text-end inv-amount">Částka</th><th>Vystaveno</th><th>Stav</th><th></th></tr>
                        </thead>
                        <tbody>
                        {% for inv in invoices %}
                            <tr>
                                <td class="inv-number"><a href="{{ path('invoice_pdf', {id: inv.id}) }}" target="_blank">{{ inv.number }}</a></td>
                                <td class="inv-type">{{ inv.type.label }}</td>
                                <td class="inv-amount text-end text-nowrap">{{ inv.totalAmount|number_format(2, ',', ' ') }} {{ inv.currency == 'CZK' ? 'Kč' : inv.currency }}</td>
                                <td class="inv-issued text-nowrap">{{ inv.issuedAt|date('d. m. Y') }}</td>
                                <td class="inv-status">
                                    {% if inv.isPaid %}
                                        <span class="badge text-bg-success">Zaplaceno {{ inv.paidAt|date('d. m. Y') }}</span>
                                    {% else %}
                                        <span class="badge text-bg-warning">Splatnost {{ inv.dueAt|date('d. m. Y') }}</span>
                                    {% endif %}
                                </td>
                                <td class="inv-actions text-end">
                                    <div class="d-flex gap-1 justify-content-end flex-wrap">
                                        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#editInvoice{{ inv.id }}">Upravit</button>
                                        {% if reservation.guestEmail %}
                                            <form method="post" action="{{ path('invoice_send_email', {id: inv.id}) }}"
                                                  onsubmit="return confirm('Poslat fakturu {{ inv.number }} hostovi na {{ reservation.guestEmail }}?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('invoice-email-' ~ inv.id) }}">
                                                <button class="btn btn-sm btn-outline-primary">Poslat e-mailem</button>
                                            </form>
                                        {% endif %}
                                        {% if not inv.isPaid %}
                                            <form method="post" action="{{ path('invoice_mark_paid', {id: inv.id}) }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('invoice-paid-' ~ inv.id) }}">
                                                <button class="btn btn-sm btn-outline-success">Zaplaceno</button>
                                            </form>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
            {% endif %}
            {% for inv in invoices %}{% include 'invoice/_edit_modal.html.twig' with {invoice: inv} %}{% endfor %}

            <div class="mt-3 d-flex gap-2 flex-wrap">
                {% set mode = reservation.billingMode %}
                {% if mode and mode.value == 'standard_with_deposit' and deposit_applies %}
                    {% if not has_deposit %}
                        {% if deposit_amount %}
                            <form method="post" action="{{ path('invoice_issue_deposit', {id: reservation.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('invoice-deposit-' ~ reservation.id) }}">
                                <button class="btn btn-sm btn-primary">Vystavit zálohu ({{ deposit_amount|number_format(0, ',', ' ') }} Kč)</button>
                            </form>
                        {% else %}
                            <p class="text-muted small mb-0">Doplň cenu rezervace, aby šlo vystavit zálohu.</p>
                        {% endif %}
                    {% endif %}
                    {% if has_deposit and not has_final %}
                        <form method="post" action="{{ path('invoice_issue_final', {id: reservation.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('invoice-final-' ~ reservation.id) }}">
                            <button class="btn btn-sm btn-primary">Vystavit doplatek</button>
                        </form>
                    {% endif %}
                {% elseif mode and mode.value == 'waived' %}
                    <p class="text-muted small mb-0">Fakturace prominuta — pobyt bez vystavení faktury.</p>
                {% elseif mode %}
                    {% if not has_full %}
                        <form method="post" action="{{ path('invoice_issue_full', {id: reservation.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('invoice-full-' ~ reservation.id) }}">
                            <button class="btn btn-sm btn-primary">Vystavit fakturu na celou částku</button>
                        </form>
                    {% endif %}
                {% else %}
                    <p class="text-muted small mb-0">Nastav fakturační režim a tlačítka pro vystavení faktury se objeví.</p>
                {% endif %}
            </div>
        </div>
    </div>

    {{ include('reservation/_timeline.html.twig') }}
{% endblock %}

{% block stylesheets %}
    <style>
        /* Karta faktur je dotazovací kontejner — tabulka se skládá podle vlastní
           šířky (na celé šířce zůstává plná tabulka, v úzkém okně se složí). */
        .invoice-card { container-type: inline-size; }

        /* Odsazení částky od sloupce Vystaveno, ať se čísla nelepí. */
        .invoice-table .inv-amount { padding-right: 2rem; }

        /* Faktury: v úzkém okně se řádek tabulky složí do dvou řádků —
           1. řádek: číslo · typ … částka, 2. řádek: stav · datum … akce. */
        @container (max-width: 560px) {
            .invoice-table thead { display: none; }
            .invoice-table, .invoice-table tbody { display: block; }
            .invoice-table tbody tr {
                display: flex;
                flex-wrap: wrap;
                align-items: center;
                column-gap: 0.4rem;
                row-gap: 0.3rem;
                padding: 0.6rem 0;
            }
            .invoice-table tbody tr + tr { border-top: 1px solid var(--bs-border-color); }
            .invoice-table td { display: block; border: 0; padding: 0; }
            /* Zalomení mezi 1. a 2. řádkem. */
            .invoice-table tbody tr::after { content: ""; flex-basis: 100%; height: 0; order: 4; }
            /* 1. řádek: číslo + typ vlevo, částka vpravo. */
            .invoice-table .inv-number { order: 1; font-weight: 600; }
            .invoice-table .inv-type { order: 2; color: var(--bs-secondary-color); font-size: 0.875rem; }
            .invoice-table .inv-type::before { content: "· "; }
            .invoice-table .inv-amount { order: 3; margin-left: auto; font-weight: 600; padding-right: 0; }
            /* 2. řádek: stav + datum vlevo, akce vpravo. */
            .invoice-table .inv-status { order: 5; }
            .invoice-table .inv-issued { order: 6; color: var(--bs-secondary-color); font-size: 0.8125rem; }
            .invoice-table .inv-issued::before { content: "vystaveno "; }
            .invoice-table .inv-actions { order: 7; margin-left: auto; }
        }
    </style>
{% endblock %}

{% block javascripts %}
    <script>
        document.querySelectorAll('[data-copy]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var input = document.querySelector(btn.dataset.copy);
                navigator.clipboard.writeText(input.value).then(function () {
                    var orig = btn.textContent;
                    btn.textContent = 'Zkopírováno';
                    setTimeout(function () { btn.textContent = orig; }, 1500);
                });
            });
        });
        document.querySelectorAll('form[data-cleaning-defaults]').forEach(function (form) {
            const defaults = JSON.parse(form.dataset.cleaningDefaults);
            const typeSelect = form.querySelector('[data-cleaning-type]');
            const costInput = form.querySelector('[data-cleaning-cost]');
            const payoutInput = form.querySelector('[data-cleaning-payout]');
            const paidAtInput = form.querySelector('[data-cleaning-paid-at]');
            if (!typeSelect || !costInput || !payoutInput) return;
            typeSelect.addEventListener('change', function () {
                const preset = defaults[typeSelect.value];
                if (!preset) return;
                costInput.value = preset.cost;
                payoutInput.value = preset.payout;
                if (paidAtInput && !paidAtInput.value) {
                    paidAtInput.value = preset.paid_at;
                }
            });
        });
    </script>
{% endblock %}
