{% extends 'base.html.twig' %}

{% block title %}Rezervace{% endblock %}

{% block body %}
    <style>
        .today-row > td {
            background-color: #fffdf3 !important;
        }
        .today-row > td:first-child {
            box-shadow: inset 3px 0 0 #f59e0b;
        }
        .today-divider > td {
            padding: 0;
            border: 0;
        }
        .today-divider .today-line {
            display: flex;
            align-items: center;
            gap: .5rem;
            padding: .15rem 0;
        }
        .today-divider .today-line::after {
            content: "";
            flex: 1;
            height: 1px;
            background: linear-gradient(to right, #f59e0b, rgba(245, 158, 11, 0));
        }
        .today-divider .today-pill {
            font-size: .7rem;
            font-weight: 600;
            letter-spacing: .03em;
            text-transform: uppercase;
            color: #b45309;
        }
        .today-divider .today-pill::before {
            content: "";
            display: inline-block;
            width: .45rem;
            height: .45rem;
            margin-right: .35rem;
            border-radius: 50%;
            background: #f59e0b;
            vertical-align: middle;
        }
    </style>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="d-flex align-items-center gap-3">
            <h1 class="h3 mb-0">Rezervace</h1>
            <a href="{{ path('reservation_new') }}" class="btn btn-sm btn-primary">+ Nová rezervace</a>
        </div>
        <div class="btn-group" role="group">
            <a href="{{ path('reservation_list') }}" class="btn btn-sm btn-outline-secondary {{ currentStatus is null ? 'active' : '' }}">Vše</a>
            {% for status in statuses %}
                <a href="{{ path('reservation_list', {status: status.value}) }}"
                   class="btn btn-sm btn-outline-secondary {{ currentStatus == status ? 'active' : '' }}">
                    {{ status.label }}
                </a>
            {% endfor %}
        </div>
    </div>

    {% if reservations is empty %}
        <div class="alert alert-info">Žádné rezervace.</div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                <tr>
                    <th>Stav</th>
                    <th>Kanál</th>
                    <th>Příjezd</th>
                    <th>Odjezd</th>
                    <th>Host</th>
                    <th class="text-end">Cena</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                {% set today = 'now'|date('Y-m-d') %}
                {% for r in reservations %}
                    {% set checkIn = r.checkIn|date('Y-m-d') %}
                    {% set checkOut = r.checkOut ? r.checkOut|date('Y-m-d') : checkIn %}
                    {% set isActive = today >= checkIn and today <= checkOut %}
                    {% set prevFuture = loop.first or reservations[loop.index0 - 1].checkIn|date('Y-m-d') > today %}
                    {% if checkIn <= today and prevFuture %}
                        <tr class="today-divider">
                            <td colspan="7"><div class="today-line"><span class="today-pill">Dnes {{ 'now'|date('j. n. Y') }}</span></div></td>
                        </tr>
                    {% endif %}
                    <tr class="{{ isActive ? 'today-row' : '' }}">
                        <td>
                            {% set badge = {
                                needs_details: 'warning',
                                confirmed: 'success',
                                in_progress: 'primary',
                                completed: 'secondary',
                                cancelled: 'dark',
                            }[r.status.value] %}
                            <span class="badge text-bg-{{ badge }}">{{ r.status.label }}</span>
                            {% if r.motopressExternalId and not r.guestEmail and r.channel.value != 'web' %}
                                <span class="badge text-bg-warning ms-1" title="MotoPress hlasi blok obsazenosti, ale chybi data hosta. Doplnit z extranetu.">⚠ z extranetu</span>
                            {% endif %}
                        </td>
                        <td>{{ r.channel.label }}</td>
                        <td>
                            {{ r.checkIn|date('d. m. Y') }}
                            {% if checkIn == today %}<span class="badge text-bg-warning ms-1">dnes</span>{% endif %}
                        </td>
                        <td>
                            {{ r.checkOut ? r.checkOut|date('d. m. Y') : '—' }}
                            {% if r.checkOut and checkOut == today %}<span class="badge text-bg-warning ms-1">dnes</span>{% endif %}
                        </td>
                        <td>
                            {{ r.guestName ?? '(nedoplněno)' }}
                            {% if r.hasPet %}<span class="badge text-bg-warning ms-1" title="{{ r.petsNote ?? 'Host se psem' }}">🐶</span>{% endif %}
                            {% if r.needsBabyCot %}<span class="badge text-bg-info ms-1" title="Připravit dětskou postýlku">👶</span>{% endif %}
                        </td>
                        <td class="text-end">
                            {% if r.priceTotal %}
                                {{ r.priceTotal|number_format(0, ',', ' ') }} {{ r.priceCurrency }}
                            {% else %}—{% endif %}
                        </td>
                        <td class="text-end">
                            <a href="{{ path('reservation_detail', {id: r.id}) }}" class="btn btn-sm btn-outline-primary">Detail</a>
                        </td>
                    </tr>
                {% endfor %}
                {% if reservations|last.checkIn|date('Y-m-d') > today %}
                    <tr class="today-divider">
                        <td colspan="7"><span class="today-pill">Dnes · {{ 'now'|date('d. m. Y') }}</span></td>
                    </tr>
                {% endif %}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}
