{% extends 'settings/base.html.twig' %}

{% block title %}Nastavení — e-maily{% endblock %}

{% block settings_active %}mail{% endblock %}

{% block settings_content_class %}col-lg-9 col-xl-10{% endblock %}

{% block settings_content %}
    <h2 class="h5 mb-2">E-maily hostům</h2>
    <p class="text-muted small">
        Společné nastavení odchozích zpráv hostům — odesílatel, patička a vzhled.
        Konkrétní texty jednotlivých zpráv najdeš v záložce <strong>Šablony zpráv</strong>,
        přístup k SMTP serveru v záložce <strong>Připojení</strong>.
    </p>

    {{ form_start(form) }}
        {{ include('mail_settings/_editor.html.twig') }}
        <div class="d-flex justify-content-end mt-3">
            <button type="submit" class="btn btn-primary">Uložit</button>
        </div>
    {{ form_end(form) }}
{% endblock %}
