{% extends 'settings/base.html.twig' %}

{% import '_partials/markdown_editor.html.twig' as md %}

{% block title %}Nastavení — e-maily{% endblock %}

{% block settings_active %}mail{% endblock %}

{% block settings_content_class %}col-lg-9 col-xl-10{% endblock %}

{% block settings_content %}
    <style>
        .theme-swatch { display:flex; flex-direction:column; gap:8px; align-items:stretch; width:100%; padding:10px; border:2px solid #dee2e6; border-radius:12px; background:#fff; cursor:pointer; transition:border-color .15s, box-shadow .15s; text-align:left; }
        .theme-swatch:hover { border-color:#adb5bd; }
        .theme-swatch.active { border-color:#0d6efd; box-shadow:0 0 0 3px rgba(13,110,253,.15); }
        .theme-swatch .swatch-colors { display:flex; width:100%; height:36px; border-radius:7px; overflow:hidden; border:1px solid rgba(0,0,0,.06); }
        .theme-swatch .swatch-colors > span { flex:1; }
        .theme-swatch .swatch-label { font-size:.85rem; font-weight:500; color:#212529; }
        #mail-preview { border:1px solid #dee2e6; border-radius:14px; overflow:hidden; box-shadow:0 1px 3px rgba(0,0,0,.06); background:#fff; }
        #mp-logo { padding:24px 20px; text-align:center; font-weight:700; font-size:1.2rem; border-bottom:1px solid #eef0f2; }
        #mp-logo img { width:92px; max-width:60%; height:auto; }
        #mp-body { padding:20px; font-size:.9rem; line-height:1.6; color:#27272a; }
        #mp-btn { display:inline-block; margin-top:6px; padding:9px 16px; border-radius:7px; color:#fff; font-size:.85rem; font-weight:600; text-decoration:none; }
        #mp-footer { padding:20px; text-align:center; color:#fff; }
        #mp-footer .mp-foot-name { font-weight:700; font-size:.92rem; }
        #mp-footer .mp-foot-contact { font-size:.8rem; color:rgba(255,255,255,.82); margin-top:2px; }
        #mp-footer .mp-foot-contact p { margin:0 0 6px; }
        #mp-footer .mp-foot-contact p:last-child { margin-bottom:0; }
        #mp-footer .mp-foot-contact a { color:#fff; text-decoration:underline; }
    </style>

    <h2 class="h5 mb-2">E-maily hostům</h2>
    <p class="text-muted small">
        Společné nastavení odchozích zpráv hostům — odesílatel, patička a vzhled.
        Konkrétní texty jednotlivých zpráv najdeš v záložce <strong>Šablony zpráv</strong>,
        přístup k SMTP serveru v záložce <strong>Připojení</strong>.
    </p>

    {{ form_start(form) }}
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card mb-3">
                <div class="card-header py-2 fw-semibold">Odesílatel</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">{{ form_row(form.senderName) }}</div>
                        <div class="col-md-6">{{ form_row(form.senderEmail) }}</div>
                    </div>
                    <div class="mt-3">{{ form_row(form.replyTo) }}</div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header py-2 fw-semibold">Vzhled</div>
                <div class="card-body">
                    <div class="d-none">{{ form_row(form.theme, { id: 'mail-theme-select' }) }}</div>

                    <label class="form-label">Barevné téma</label>
                    <div class="row g-2 mb-3">
                        {% for t in themes %}
                            <div class="col-6 col-md-4">
                                <button type="button" class="theme-swatch js-swatch" data-theme="{{ t.key }}" data-primary="{{ t.primary }}" data-accent="{{ t.accent }}">
                                    <span class="swatch-colors">
                                        <span style="background:{{ t.primary }}"></span>
                                        <span style="background:{{ t.accent }}"></span>
                                    </span>
                                    <span class="swatch-label">{{ t.label }}</span>
                                </button>
                            </div>
                        {% endfor %}
                        <div class="col-6 col-md-4">
                            <button type="button" class="theme-swatch js-swatch" data-theme="custom">
                                <span class="swatch-colors">
                                    <span id="swatch-custom-primary"></span>
                                    <span id="swatch-custom-accent"></span>
                                </span>
                                <span class="swatch-label">Vlastní barvy</span>
                            </button>
                        </div>
                    </div>

                    <div id="custom-colors" class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label small mb-1">Primární (záhlaví)</label>
                            <div class="input-group">
                                <input type="color" class="form-control form-control-color" id="picker-primary" title="Primární barva">
                                {{ form_widget(form.colorPrimary, { id: 'hex-primary', attr: { class: 'form-control', maxlength: 7, placeholder: '#334155' } }) }}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small mb-1">Akcentní (tlačítka, odkazy)</label>
                            <div class="input-group">
                                <input type="color" class="form-control form-control-color" id="picker-accent" title="Akcentní barva">
                                {{ form_widget(form.colorAccent, { id: 'hex-accent', attr: { class: 'form-control', maxlength: 7, placeholder: '#0ea5e9' } }) }}
                            </div>
                        </div>
                    </div>

                    <div class="mt-2">{{ form_row(form.showLogo) }}</div>
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header py-2 fw-semibold">Patička</div>
                <div class="card-body">
                    {{ form_label(form.footer) }}
                    {{ md.toolbar(form.footer) }}
                    {{ form_widget(form.footer) }}
                    {{ form_help(form.footer) }}
                    {{ form_errors(form.footer) }}
                </div>
            </div>

            <div class="d-flex justify-content-end">
                <button type="submit" class="btn btn-primary">Uložit</button>
            </div>
        </div>

        <div class="col-lg-5">
            <label class="form-label">Náhled vzhledu</label>
            <div id="mail-preview">
                <div id="mp-logo">
                    <img id="mp-logo-img" src="{{ asset(logoUrl|trim('/')) }}" alt="" style="display:none;">
                    <span id="mp-logo-name">{{ form.senderName.vars.value|default('Vaše ubytování') }}</span>
                </div>
                <div id="mp-body">
                    <p class="mb-2">Dobrý den, už se na vás těšíme. Připomínáme detaily vašeho pobytu a&nbsp;těšíme se na vaši návštěvu.</p>
                    <div style="text-align:center;"><a href="#" id="mp-btn" onclick="return false;">Online check-in</a></div>
                </div>
                <div id="mp-footer">
                    <div class="mp-foot-name" id="mp-foot-name">{{ form.senderName.vars.value|default('Vaše ubytování') }}</div>
                    <div class="mp-foot-contact" id="mp-foot-contact"></div>
                </div>
            </div>
            <p class="text-muted small mt-2">Náhled bere logo i&nbsp;patičku z&nbsp;nastavení. Patička se renderuje z&nbsp;Markdownu server-side, shodně se skutečným e-mailem (proměnné s&nbsp;ukázkovými daty).</p>
        </div>
    </div>
    {{ form_end(form) }}
{% endblock %}

{% block javascripts %}
{{ md.assets() }}
<script>
    (function () {
        const select = document.getElementById('mail-theme-select');
        const swatches = Array.prototype.slice.call(document.querySelectorAll('.js-swatch'));
        const customWrap = document.getElementById('custom-colors');
        const pickerP = document.getElementById('picker-primary');
        const pickerA = document.getElementById('picker-accent');
        const hexP = document.getElementById('hex-primary');
        const hexA = document.getElementById('hex-accent');
        const dotP = document.getElementById('swatch-custom-primary');
        const dotA = document.getElementById('swatch-custom-accent');
        const mpLogo = document.getElementById('mp-logo');
        const mpLogoImg = document.getElementById('mp-logo-img');
        const mpLogoName = document.getElementById('mp-logo-name');
        const mpFooter = document.getElementById('mp-footer');
        const mpFootName = document.getElementById('mp-foot-name');
        const mpFootContact = document.getElementById('mp-foot-contact');
        const mpBtn = document.getElementById('mp-btn');
        const senderName = document.querySelector('[name$="[senderName]"]');
        const showLogo = document.querySelector('[name$="[showLogo]"]');
        const footer = document.querySelector('[name$="[footer]"]');
        const HAS_LOGO = {{ hasLogo ? 'true' : 'false' }};
        const FOOTER_PREVIEW_URL = {{ path('mail_settings_footer_preview')|json_encode|raw }};

        const HEX6 = /^#[0-9a-fA-F]{6}$/;
        const fallback = (v, def) => HEX6.test((v || '').trim()) ? v.trim() : def;

        function colors() {
            if (select.value === 'custom') {
                return { primary: fallback(hexP.value, '#334155'), accent: fallback(hexA.value, '#0ea5e9') };
            }
            const s = swatches.find(x => x.dataset.theme === select.value) || swatches[0];
            return { primary: s.dataset.primary, accent: s.dataset.accent };
        }

        function updatePreview() {
            const c = colors();
            mpLogo.style.color = c.primary;
            mpFooter.style.background = c.primary;
            mpBtn.style.background = c.accent;
        }

        function updateLogo() {
            const useImg = HAS_LOGO && showLogo && showLogo.checked;
            mpLogoImg.style.display = useImg ? 'inline-block' : 'none';
            mpLogoName.style.display = useImg ? 'none' : 'inline';
        }

        let footerTimer = null;
        async function updateFooter() {
            const raw = footer && footer.value || '';
            if (raw.trim() === '') {
                mpFootContact.innerHTML = '';
                mpFootContact.style.display = 'none';
                return;
            }
            try {
                const res = await fetch(FOOTER_PREVIEW_URL, { method: 'POST', body: new URLSearchParams({ footer: raw }) });
                mpFootContact.innerHTML = await res.text();
            } catch (e) {
                mpFootContact.textContent = raw;
            }
            mpFootContact.style.display = '';
        }
        function scheduleFooter() { clearTimeout(footerTimer); footerTimer = setTimeout(updateFooter, 400); }

        function syncDots() {
            dotP.style.background = fallback(hexP.value, '#334155');
            dotA.style.background = fallback(hexA.value, '#0ea5e9');
        }

        function refresh() {
            swatches.forEach(s => s.classList.toggle('active', s.dataset.theme === select.value));
            customWrap.style.display = select.value === 'custom' ? '' : 'none';
            updatePreview();
        }

        swatches.forEach(s => s.addEventListener('click', function () {
            select.value = s.dataset.theme;
            refresh();
        }));

        pickerP.addEventListener('input', function () { hexP.value = pickerP.value; syncDots(); if (select.value === 'custom') updatePreview(); });
        pickerA.addEventListener('input', function () { hexA.value = pickerA.value; syncDots(); if (select.value === 'custom') updatePreview(); });
        hexP.addEventListener('input', function () { if (HEX6.test(hexP.value)) pickerP.value = hexP.value; syncDots(); if (select.value === 'custom') updatePreview(); });
        hexA.addEventListener('input', function () { if (HEX6.test(hexA.value)) pickerA.value = hexA.value; syncDots(); if (select.value === 'custom') updatePreview(); });
        if (senderName) senderName.addEventListener('input', function () {
            const name = senderName.value || 'Vaše ubytování';
            mpLogoName.textContent = name;
            mpFootName.textContent = name;
        });
        if (showLogo) showLogo.addEventListener('change', updateLogo);
        if (footer) footer.addEventListener('input', scheduleFooter);

        pickerP.value = fallback(hexP.value, '#334155');
        pickerA.value = fallback(hexA.value, '#0ea5e9');
        syncDots();
        refresh();
        updateLogo();
        updateFooter();
    })();
</script>
{% endblock %}
