{% extends 'base.html.twig' %}

{% block title %}Nastavení — obecné{% endblock %}

{% block body %}
    <h1 class="h3 mb-3">Nastavení</h1>

    {{ include('settings/_nav.html.twig', { active: 'general' }) }}

    <h2 class="h5 mb-2">Obecné</h2>
    <p class="text-muted small">
        Základní identita instance — název a veřejná adresa aplikace.
    </p>

    <div class="col-lg-8">
        {{ form_start(form) }}
            <div class="card mb-3">
                <div class="card-body">
                    <div class="mb-3">{{ form_row(form.brandName) }}</div>
                    <div class="mb-3">{{ form_row(form.baseUrl) }}</div>
                </div>
            </div>

            <div class="d-flex justify-content-end">
                <button type="submit" class="btn btn-primary">Uložit</button>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
