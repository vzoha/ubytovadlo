{% extends 'base.html.twig' %}

{% block title %}DPH {{ '%04d-%02d'|format(summary.year, summary.month) }}{% endblock %}

{% block body %}
    {% set is_payer = taxProfile.value == 'vat_payer' %}
    {% set filing_amount = is_payer ? summary.liability.totalCzk|round : summary.filingVatCzk %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <a href="{{ path('vat_list') }}" class="text-decoration-none small">← všechny měsíce</a>
            <h1 class="h3 mb-0 mt-1">DPH za {{ '%04d-%02d'|format(summary.year, summary.month) }}</h1>
        </div>
        {% set period = summary.period %}
        <div class="d-flex align-items-center gap-2">
            <a href="{{ path('vat_csv', {year: summary.year, month: '%02d'|format(summary.month)}) }}" class="btn btn-sm btn-outline-secondary">Stáhnout podklad (CSV)</a>
            {% if period and period.filedAt %}
                <span class="badge text-bg-secondary fs-6">odesláno {{ period.filedAt|date('d. m. Y') }}</span>
                {% if period.paidAt %}
                    <span class="badge text-bg-success fs-6">zaplaceno {{ period.paidAt|date('d. m. Y') }}{% if period.paidAmountCzk %} · {{ period.paidAmountCzk|number_format(0, ',', ' ') }} Kč{% endif %}</span>
                {% else %}
                    <span class="badge text-bg-warning fs-6">nezaplaceno</span>
                {% endif %}
            {% endif %}
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-white"><strong>Podání + úhrada na FÚ</strong></div>
        <div class="card-body">
            <form method="post" action="{{ path('vat_mark_filed', {year: summary.year, month: '%02d'|format(summary.month)}) }}" class="row g-3 align-items-end">
                <input type="hidden" name="_token" value="{{ csrf_token('vat-file-' ~ summary.year ~ '-' ~ summary.month) }}">
                <div class="col-md-3">
                    <label class="form-label small mb-1">Datum podání</label>
                    <input type="date" name="filed_at" class="form-control" value="{{ period and period.filedAt ? period.filedAt|date('Y-m-d') : '' }}">
                </div>
                <div class="col-md-3">
                    <label class="form-label small mb-1">Datum úhrady</label>
                    <input type="date" name="paid_at" class="form-control" value="{{ period and period.paidAt ? period.paidAt|date('Y-m-d') : '' }}">
                </div>
                <div class="col-md-3">
                    <label class="form-label small mb-1">Zaplaceno Kč</label>
                    <input type="text" inputmode="decimal" name="paid_amount_czk" class="form-control" placeholder="{{ filing_amount }}" value="{{ period ? period.paidAmountCzk ?? '' : '' }}">
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100">Uložit</button>
                </div>
            </form>
            {% if period and period.paidAmountCzk %}
                {% set delta = (period.paidAmountCzk - filing_amount)|round(2) %}
                {% if delta|abs < 0.5 %}
                    <div class="text-success small mt-2">✓ úhrada sedí s DPH přiznáním ({{ filing_amount|number_format(0, ',', ' ') }} Kč)</div>
                {% else %}
                    <div class="text-danger small mt-2">Δ {{ delta|number_format(2, ',', ' ') }} Kč oproti přiznání ({{ filing_amount|number_format(0, ',', ' ') }} Kč)</div>
                {% endif %}
            {% endif %}
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <div class="small text-muted">Základ pro DPH (Σ)</div>
                    <div class="h4 mb-0">{{ summary.sumBaseCzk|number_format(2, ',', ' ') }} Kč</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-primary">
                <div class="card-body">
                    <div class="small text-muted">DPH 21 % (Σ)</div>
                    <div class="h4 mb-0 text-primary">{{ summary.sumVatCzk|number_format(2, ',', ' ') }} Kč</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <div class="small text-muted">Lhůta podání + úhrady</div>
                    <div class="h4 mb-0">{{ summary.filingDueAt|date('d. m. Y') }}</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <div class="small text-muted">Rezervací (provize OTA)</div>
                    <div class="h4 mb-0">{{ summary.reservations|length }}</div>
                </div>
            </div>
        </div>
    </div>

    {% if is_payer %}
        <div class="card mb-4">
            <div class="card-header bg-white"><strong>Daňová povinnost</strong> <span class="text-muted small">(plátce DPH)</span></div>
            <div class="card-body">
                <table class="table table-sm mb-0" style="max-width: 32rem;">
                    <tr>
                        <td>Výstupní DPH z faktur hostům (12 %)</td>
                        <td class="text-end">{{ summary.liability.outputVatCzk|number_format(2, ',', ' ') }} Kč</td>
                    </tr>
                    <tr>
                        <td>Reverse charge z provize (21 %)</td>
                        <td class="text-end">{{ summary.liability.reverseChargeVatCzk|number_format(2, ',', ' ') }} Kč</td>
                    </tr>
                    <tr>
                        <td>Odpočet DPH na vstupu (RC)</td>
                        <td class="text-end text-success">− {{ summary.liability.deductibleVatCzk|number_format(2, ',', ' ') }} Kč</td>
                    </tr>
                    <tr class="border-top">
                        <td class="fw-bold">Daňová povinnost</td>
                        <td class="text-end fw-bold">{{ summary.liability.totalCzk|number_format(2, ',', ' ') }} Kč</td>
                    </tr>
                </table>
                <div class="small text-muted mt-2">Základ výstupu {{ summary.outputBaseCzk|number_format(2, ',', ' ') }} Kč. Reverse charge z provize má nárok na odpočet, takže se vyruší — k úhradě zbývá výstupní daň.</div>
            </div>
        </div>
    {% endif %}

    <h2 class="h5">Doklady od OTA</h2>
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-white">
                    <strong>Booking.com</strong>
                    <span class="text-muted small">(měsíční faktura z e-mailu)</span>
                </div>
                <div class="card-body">
                    {% if summary.invoice %}
                        <div><strong>#{{ summary.invoice.invoiceNumber }}</strong> · vystaveno {{ summary.invoice.issuedAt|date('d. m. Y') }}</div>
                        <div class="small text-muted mb-2">Období {{ summary.invoice.periodFrom|date('d. m.') }} – {{ summary.invoice.periodTo|date('d. m. Y') }}</div>
                        <div>Provize {{ summary.invoice.commission|number_format(2, ',', ' ') }} {{ summary.invoice.currency }} + payment fee {{ summary.invoice.paymentFee|number_format(2, ',', ' ') }} {{ summary.invoice.currency }}</div>
                        <div class="mb-2"><strong>K zaplacení {{ summary.invoice.totalPayable|number_format(2, ',', ' ') }} {{ summary.invoice.currency }}</strong></div>
                        {% if summary.bookingDelta is not null %}
                            {% if summary.bookingDelta|abs < 0.01 %}
                                <div class="text-success small mb-2">✓ souhrn rezervací sedí přesně ({{ summary.bookingReservationSum|number_format(2, ',', ' ') }} {{ summary.invoice.currency }})</div>
                            {% else %}
                                <div class="text-danger small mb-2">Δ {{ summary.bookingDelta|number_format(2, ',', ' ') }} {{ summary.invoice.currency }} (rezervace {{ summary.bookingReservationSum|number_format(2, ',', ' ') }})</div>
                            {% endif %}
                        {% endif %}
                        <a href="{{ path('vat_booking_invoice_pdf', {id: summary.invoice.id}) }}" target="_blank" class="btn btn-sm btn-outline-secondary">
                            📄 Otevřít PDF
                        </a>
                    {% else %}
                        <p class="text-muted mb-0">Booking faktura zatím nepřišla — typicky chodí 3. den následujícího měsíce.</p>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <div>
                        <strong>Airbnb</strong>
                        <span class="text-muted small">(ručně nahraný receipt)</span>
                    </div>
                    <a href="{{ path('vat_airbnb_upload', {year: summary.year, month: '%02d'|format(summary.month)}) }}" class="btn btn-sm btn-outline-secondary">
                        {{ summary.airbnbStatements is empty ? 'Nahrát' : 'Přidat další' }}
                    </a>
                </div>
                <div class="card-body">
                    {% if summary.airbnbReservations is empty and summary.airbnbStatements is empty %}
                        <p class="text-muted mb-0">V tomto měsíci žádné Airbnb rezervace.</p>
                    {% else %}
                        {% if summary.airbnbStatements is not empty %}
                            <div class="mb-2"><strong>Servisní poplatek hostitele celkem {{ summary.airbnbStatementSum|number_format(2, ',', ' ') }} Kč</strong></div>
                            {% if summary.airbnbDelta is not null %}
                                {% if summary.airbnbDelta|abs < 0.01 %}
                                    <div class="text-success small mb-2">✓ souhrn rezervací sedí ({{ summary.airbnbReservationSum|number_format(2, ',', ' ') }} Kč)</div>
                                {% else %}
                                    <div class="text-warning small mb-2">Δ {{ summary.airbnbDelta|number_format(2, ',', ' ') }} Kč oproti rezervacím ({{ summary.airbnbReservationSum|number_format(2, ',', ' ') }} Kč)</div>
                                {% endif %}
                            {% endif %}
                        {% endif %}

                        {# Per-rezervační stav dokladu — chybějící jdou rovnou na předvyplněný upload. #}
                        <ul class="list-unstyled small mb-0">
                            {% for r in summary.airbnbReservations %}
                                {% set s = summary.airbnbStatementByReservation[r.id] ?? null %}
                                <li class="d-flex justify-content-between align-items-center py-1 border-top">
                                    <span>
                                        {{ r.checkIn|date('d. m.') }}–{{ r.checkOut|date('d. m. Y') }}
                                        · {{ r.guestName ?? '(host)' }}
                                        {% if s %}
                                            · <strong>{{ s.commissionCzk|number_format(2, ',', ' ') }} Kč</strong>
                                            <span class="text-success">· ✓ doklad</span>
                                        {% else %}
                                            · <strong>{{ r.commissionAmount|number_format(2, ',', ' ') }} Kč</strong>
                                            <span class="text-warning">· ⚠ chybí doklad</span>
                                        {% endif %}
                                    </span>
                                    <span class="d-flex gap-1">
                                        {% if s %}
                                            <a href="{{ path('vat_airbnb_statement_pdf', {id: s.id}) }}" target="_blank" class="btn btn-sm btn-outline-secondary">📄</a>
                                            <form method="post" action="{{ path('vat_airbnb_statement_delete', {id: s.id}) }}" onsubmit="return confirm('Smazat Airbnb receipt?');" class="d-inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('vat-airbnb-delete-' ~ s.id) }}">
                                                <button class="btn btn-sm btn-outline-danger py-0" type="submit">×</button>
                                            </form>
                                        {% else %}
                                            <a href="{{ path('vat_airbnb_upload', {year: summary.year, month: '%02d'|format(summary.month), reservation: r.id}) }}" class="btn btn-sm btn-warning">Nahrát</a>
                                        {% endif %}
                                    </span>
                                </li>
                            {% endfor %}

                            {# Doklady bez vazby na rezervaci (starší / ručně nahrané). #}
                            {% for s in summary.airbnbUnlinkedStatements %}
                                <li class="d-flex justify-content-between align-items-center py-1 border-top">
                                    <span>
                                        {{ s.periodFrom|date('d. m.') }}–{{ s.periodTo|date('d. m. Y') }}
                                        · <strong>{{ s.commissionCzk|number_format(2, ',', ' ') }} Kč</strong>
                                        {% if s.notes %}<span class="text-muted">· {{ s.notes }}</span>{% endif %}
                                    </span>
                                    <span class="d-flex gap-1">
                                        <a href="{{ path('vat_airbnb_statement_pdf', {id: s.id}) }}" target="_blank" class="btn btn-sm btn-outline-primary">📄</a>
                                        <form method="post" action="{{ path('vat_airbnb_statement_delete', {id: s.id}) }}" onsubmit="return confirm('Smazat Airbnb receipt?');" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('vat-airbnb-delete-' ~ s.id) }}">
                                            <button class="btn btn-sm btn-outline-danger py-0" type="submit">×</button>
                                        </form>
                                    </span>
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <h2 class="h5">Rezervace s odjezdem v měsíci</h2>
    {% if summary.reservations is empty %}
        <div class="alert alert-info">Žádné rezervace s vyplněnou provizí.</div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                <tr>
                    <th>Kanál</th>
                    <th>Odjezd</th>
                    <th>Host</th>
                    <th class="text-end">Provize</th>
                    <th class="text-end">Kurz ČNB</th>
                    <th class="text-end">Základ Kč</th>
                    <th class="text-end">DPH 21 %</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                {% for r in summary.reservations %}
                    <tr>
                        <td>{{ r.channel.label }}</td>
                        <td>{{ r.checkOut|date('d. m. Y') }}</td>
                        <td>{{ r.guestName ?? '(nedoplněno)' }}</td>
                        <td class="text-end">{{ r.commissionAmount|number_format(2, ',', ' ') }} {{ r.commissionCurrency ?? 'CZK' }}</td>
                        <td class="text-end small text-muted">
                            {% if r.vatCnbRate %}
                                {{ r.vatCnbRate|number_format(3, ',', ' ') }}<br>
                                <span class="text-muted">{{ r.vatCnbRateDate|date('d. m.') }}</span>
                            {% else %}—{% endif %}
                        </td>
                        <td class="text-end">{{ r.vatBaseCzk ? r.vatBaseCzk|number_format(2, ',', ' ') : '—' }}</td>
                        <td class="text-end"><strong>{{ r.vatAmountCzk ? r.vatAmountCzk|number_format(2, ',', ' ') : '—' }}</strong></td>
                        <td class="text-end">
                            <a href="{{ path('reservation_detail', {id: r.id}) }}" class="btn btn-sm btn-outline-secondary">↗</a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
                <tfoot>
                <tr class="table-light">
                    <th colspan="5" class="text-end">Σ</th>
                    <th class="text-end">{{ summary.sumBaseCzk|number_format(2, ',', ' ') }}</th>
                    <th class="text-end">{{ summary.sumVatCzk|number_format(2, ',', ' ') }}</th>
                    <th></th>
                </tr>
                </tfoot>
            </table>
        </div>
    {% endif %}

    <h2 class="h5 mt-4">Pro DPH přiznání</h2>
    <p class="mb-2">Řádek <strong>5</strong> přiznání („Pořízení služby s místem plnění podle § 9 odst. 1 od osoby registrované k dani v jiném členském státě") — hodnoty zaokrouhlené na celé Kč podle § 101 ZDPH:</p>
    <div class="card bg-light mb-3">
        <div class="card-body">
            <table class="table table-borderless mb-0">
                <tr>
                    <th>Základ daně</th>
                    <td class="text-end"><strong class="h5">{{ summary.filingBaseCzk|number_format(0, ',', ' ') }} Kč</strong></td>
                    <td class="text-muted small">(z {{ summary.sumBaseCzk|number_format(2, ',', ' ') }} Kč přesně)</td>
                </tr>
                <tr>
                    <th>Daň 21 %</th>
                    <td class="text-end"><strong class="h5 text-primary">{{ summary.filingVatCzk|number_format(0, ',', ' ') }} Kč</strong></td>
                    <td class="text-muted small">(z {{ summary.sumVatCzk|number_format(2, ',', ' ') }} Kč přesně)</td>
                </tr>
            </table>
        </div>
    </div>
    <p class="text-muted small mb-0">Bez nároku na odpočet (identifikovaná osoba). Souhrnné ani kontrolní hlášení u přijatých služeb nepodává.</p>
{% endblock %}
