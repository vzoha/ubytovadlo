<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Online check-in — {{ brand_name }}{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%22112%22>🏡</text></svg>">
    <link href="{{ asset('assets/bootstrap.min.css') }}" rel="stylesheet">
</head>
<body class="bg-light">
<nav class="navbar navbar-dark bg-dark mb-4">
    <div class="container">
        <span class="navbar-brand">🏡 {{ brand_name }} — online check-in</span>
    </div>
</nav>
<main class="container pb-5">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}
    {% block body %}{% endblock %}
</main>
<footer class="container text-center text-muted small pb-4 pt-2">
    Powered by <a href="{{ product_url }}" target="_blank" rel="noopener" class="text-decoration-none">{{ product_name }}</a>
    · © {{ "now"|date("Y") }}
</footer>
<script src="{{ asset('assets/bootstrap.bundle.min.js') }}"></script>
</body>
</html>
