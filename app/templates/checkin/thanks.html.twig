{% extends 'checkin/_base.html.twig' %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-lg-7 text-center">
            <div class="display-1 mb-3">🙏</div>
            <h1 class="h3 mb-2">{{ 'thanks.title'|trans({}, 'checkin') }}</h1>
            <p class="lead">{{ 'thanks.lead'|trans({'%date%': reservation.checkIn|date('d. m. Y')}, 'checkin') }}</p>
            {% set contact = issuer.current.web|default('')|replace({'https://': '', 'http://': ''})|trim('/') %}
            <p class="text-muted small">
                {% if contact %}
                    {{ 'thanks.contact_with'|trans({'%contact%': '<strong>' ~ contact ~ '</strong>'}, 'checkin')|raw }}
                {% else %}
                    {{ 'thanks.contact_plain'|trans({}, 'checkin') }}
                {% endif %}
            </p>
        </div>
    </div>
{% endblock %}
