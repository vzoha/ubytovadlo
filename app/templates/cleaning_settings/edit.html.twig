{% extends 'base.html.twig' %}

{% block title %}Nastavení úklidu{% endblock %}

{% block body %}
    <h1 class="h3 mb-3">Nastavení</h1>

    <ul class="nav nav-pills mb-4">
        <li class="nav-item">
            <a class="nav-link" href="{{ path('accommodation_profile_edit') }}">Ubytovací zařízení</a>
        </li>
        <li class="nav-item">
            <a class="nav-link active" href="{{ path('cleaning_settings_edit') }}">Úklid</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="{{ path('issuer_settings_edit') }}">Dodavatel</a>
        </li>
    </ul>

    <h2 class="h5 mb-2">Typy úklidu — názvy a ceník</h2>
    <p class="text-muted small">
        Pro každý typ úklidu nastav konkrétní název (např. jméno uklízečky) a ceník.
        Cena se účtuje podle počtu hostů: do prahu včetně platí nižší, nad práh vyšší.
        Stejná cena v obou polích = paušál. Název nech prázdný pro výchozí obecný.
    </p>

    <div class="col-lg-9">
        {{ form_start(form) }}
            {% for type in types %}
                <div class="card mb-3">
                    <div class="card-header py-2 fw-semibold">{{ type.label }}</div>
                    <div class="card-body">
                        <div class="mb-3">{{ form_row(form[type.value ~ '_label']) }}</div>
                        <div class="row g-3">
                            <div class="col-md-4">{{ form_row(form[type.value ~ '_threshold']) }}</div>
                            <div class="col-md-4">{{ form_row(form[type.value ~ '_small']) }}</div>
                            <div class="col-md-4">{{ form_row(form[type.value ~ '_large']) }}</div>
                        </div>
                    </div>
                </div>
            {% endfor %}
            <div class="d-flex justify-content-end">
                <button type="submit" class="btn btn-primary">Uložit</button>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
