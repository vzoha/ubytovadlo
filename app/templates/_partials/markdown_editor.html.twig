{% macro toolbar(field, cta = false) %}
    {% import _self as ed %}
    {% set id = field.vars.id %}
    <div class="btn-toolbar md-editor-toolbar gap-1" role="toolbar" aria-label="Formátování textu" data-md-for="{{ id }}">
        <div class="btn-group btn-group-sm" role="group" aria-label="Historie">
            <button type="button" class="btn btn-outline-secondary" data-md-action="undo" title="Zpět (Ctrl+Z)">{{ ed._svg('undo') }}</button>
            <button type="button" class="btn btn-outline-secondary" data-md-action="redo" title="Vpřed (Ctrl+Shift+Z)">{{ ed._svg('redo') }}</button>
        </div>
        <markdown-toolbar for="{{ id }}" class="btn-group btn-group-sm" role="group" aria-label="Styl">
            <md-bold class="btn btn-outline-secondary" title="Tučně (Ctrl+B)">{{ ed._svg('bold') }}</md-bold>
            <md-italic class="btn btn-outline-secondary" title="Kurzíva (Ctrl+I)">{{ ed._svg('italic') }}</md-italic>
            <md-header class="btn btn-outline-secondary" title="Nadpis">{{ ed._svg('header') }}</md-header>
        </markdown-toolbar>
        <markdown-toolbar for="{{ id }}" class="btn-group btn-group-sm" role="group" aria-label="Vložení">
            <md-link class="btn btn-outline-secondary" title="Odkaz (Ctrl+K)">{{ ed._svg('link') }}</md-link>
            <md-quote class="btn btn-outline-secondary" title="Citace">{{ ed._svg('quote') }}</md-quote>
            <md-code class="btn btn-outline-secondary" title="Kód">{{ ed._svg('code') }}</md-code>
        </markdown-toolbar>
        <markdown-toolbar for="{{ id }}" class="btn-group btn-group-sm" role="group" aria-label="Seznamy">
            <md-unordered-list class="btn btn-outline-secondary" title="Odrážky">{{ ed._svg('list-ul') }}</md-unordered-list>
            <md-ordered-list class="btn btn-outline-secondary" title="Číslovaný seznam">{{ ed._svg('list-ol') }}</md-ordered-list>
        </markdown-toolbar>
        <div class="btn-group btn-group-sm" role="group" aria-label="Oddělovač">
            <button type="button" class="btn btn-outline-secondary" data-md-insert="hr" title="Oddělovač">{{ ed._svg('hr') }}</button>
        </div>
        {% if cta %}
            <div class="btn-group btn-group-sm" role="group" aria-label="Tlačítko">
                <button type="button" class="btn btn-outline-secondary" data-md-insert="button" title="Tlačítko do e-mailu (CTA odkaz)">{{ ed._svg('button') }}</button>
            </div>
        {% endif %}
    </div>
{% endmacro %}

{% macro assets() %}
    <style>
        .md-editor-toolbar { flex-wrap: wrap; background:#f8f9fa; border:1px solid #ced4da; border-bottom:0; border-radius:.375rem .375rem 0 0; padding:.3rem; }
        .md-editor-toolbar + textarea { border-top-left-radius:0; border-top-right-radius:0; }
        .md-editor-toolbar md-bold, .md-editor-toolbar md-italic, .md-editor-toolbar md-header,
        .md-editor-toolbar md-link, .md-editor-toolbar md-quote, .md-editor-toolbar md-code,
        .md-editor-toolbar md-unordered-list, .md-editor-toolbar md-ordered-list { display:inline-flex; align-items:center; cursor:pointer; }
        .md-editor-toolbar .btn { display:inline-flex; align-items:center; }
    </style>
    <script type="module" src="{{ asset('assets/markdown-toolbar-element.js') }}"></script>
    <script src="{{ asset('assets/markdown-editor.js') }}"></script>
{% endmacro %}
