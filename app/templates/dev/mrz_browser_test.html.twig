<!DOCTYPE html>
<html lang="cs">
<head>
<meta charset="utf-8">
<title>MRZ browser pipeline test</title>
<style>
  body { font: 13px monospace; margin: 16px; }
  table { border-collapse: collapse; }
  td, th { border: 1px solid #ccc; padding: 2px 6px; }
  .ok { color: #176; } .bad { color: #b00; font-weight: bold; }
  #summary { font-size: 15px; font-weight: bold; margin: 10px 0; }
</style>
</head>
<body>
<h1>MRZ browser pipeline test</h1>
<p>Drives the REAL production browser OCR pipeline (Canvas preprocessing +
tesseract.js + parseMany) over the local corpus, scoring per field against
ground truth — the frontend counterpart of <code>app:mrz:test</code>. The image
processing steps come from <code>assets/mrz-image.js</code>, the same module the
guest check-in runs. Query params: <code>?only=a.jpg,b.jpg</code>, <code>?debug=1</code>
(stores raw reads in <code>window.__MRZ_RAW</code>).</p>
<div id="status">Init…</div>
<div id="summary"></div>
<table id="results">
  <thead><tr><th>Soubor</th><th>Příjm.</th><th>Jméno</th><th>Nar.</th><th>Doklad</th><th>Stát</th><th>Typ</th><th>OK</th></tr></thead>
  <tbody></tbody>
</table>

<script src="https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js"></script>
<script src="{{ asset('assets/mrz-image.js') }}"></script>
<script>
// Obrazové kroky sdílí check-in i vývojářský test — viz assets/mrz-image.js.
var toGrey = MrzImage.toGrey;
var otsuFromGrey = MrzImage.otsuFromGrey;
var applyThreshold = MrzImage.applyThreshold;
var otsuBinarize = MrzImage.otsuBinarize;
var adaptiveBinarize = MrzImage.adaptiveBinarize;
var detectMrzBand = MrzImage.detectMrzBand;
var cloneCanvas = MrzImage.cloneCanvas;
var sharpenCanvas = MrzImage.sharpenCanvas;
var binarizeCanvas = MrzImage.binarizeCanvas;
var adaptWin = MrzImage.adaptWin;
var binAdaptW = MrzImage.binAdaptW;
var mrzClean = MrzImage.mrzClean;
var isAnchor = MrzImage.isAnchor;
var isNumericMrz = MrzImage.isNumericMrz;
var bottomCluster = MrzImage.bottomCluster;
var recropBlock = MrzImage.recropBlock;

window.__MRZ_DONE = false;
window.__MRZ_SUMMARY = null;
window.__MRZ_RAW = {};
var GROUND_TRUTH = {{ groundTruth|json_encode|raw }};
var FIELDS = ['lastName','firstName','birthDate','documentNumber','nationalityCode','documentType'];
var statusEl = document.getElementById('status');
var tbody = document.querySelector('#results tbody');

// ─── Corpus-specific pipeline (image steps live in assets/mrz-image.js) ────
function preprocessLoadedImage(img){
  var detectW=Math.min(1600,img.width), detectScale=detectW/img.width, detectH=Math.floor(img.height*detectScale);
  var dc=document.createElement('canvas'); dc.width=detectW; dc.height=detectH;
  var dctx=dc.getContext('2d'); dctx.drawImage(img,0,0,detectW,detectH);
  var dData=dctx.getImageData(0,0,detectW,detectH); otsuBinarize(dData.data);
  var detection=detectMrzBand(dData.data,detectW,detectH);
  var cropY, cropH;
  if(detection){
    var pad=Math.max(8,Math.floor(detection.lineHeight*0.8));
    var detS=Math.max(0,detection.s-pad), detE=Math.min(detectH-1,detection.e+pad);
    cropY=Math.floor(detS/detectScale); cropH=Math.floor((detE-detS)/detectScale);
  } else { cropY=Math.floor(img.height*0.65); cropH=img.height-cropY; }
  var scale=3, maxCanvasW=3000; if(img.width*scale>maxCanvasW) scale=maxCanvasW/img.width;
  var canvas=document.createElement('canvas'); canvas.width=Math.floor(img.width*scale); canvas.height=Math.floor(cropH*scale);
  var ctx=canvas.getContext('2d'); ctx.imageSmoothingEnabled=true; ctx.imageSmoothingQuality='high';
  ctx.drawImage(img,0,cropY,img.width,cropH,0,0,canvas.width,canvas.height);
  return {canvas:canvas,detection:detection};
}
var workerPromise=null;
function getOcrWorker(){ if(!workerPromise){ workerPromise=Tesseract.createWorker('mrz',1,{langPath:'{{ asset('assets/tessdata') }}'}); } return workerPromise; }
function ocrImage(src,psm){ return getOcrWorker().then(function(w){ return w.setParameters({tessedit_pageseg_mode:String(psm)}).then(function(){return w.recognize(src);}).then(function(r){return r.data.text||'';}); }); }
// Mirror of buildPasses() in checkin/host.html.twig: the detected band binarized
// two ways + one whole-image raw pass. The backend votes across these reads.
function buildPasses(prep,imgEl){
  var passes=[];
  if(prep.canvas){
    passes.push({name:'band-adaptive',run:function(){var c=cloneCanvas(prep.canvas);sharpenCanvas(c);binarizeCanvas(c,'adaptive');return ocrImage(c,6);}});
    passes.push({name:'band-otsu',run:function(){var c=cloneCanvas(prep.canvas);sharpenCanvas(c);binarizeCanvas(c,'otsu');return ocrImage(c,6);}});
  }
  passes.push({name:'full raw',run:function(){return ocrImage(imgEl,6);}});
  return passes;
}

// ─── Locate-then-recrop (EXPERIMENTAL) ──────────────────────────────────────
// Use tesseract's own line boxes to find the MRZ, then re-OCR a tight high-res
// crop of just those lines. Line detection is what tesseract does well; a tight
// crop removes the content bleed-in that prepends stray glyphs to the surname
// ("BVLATUSEK" → "LATUSEK"). Anchors = lines with ≥2 '<' (name/filler rows);
// the all-digit numeric MRZ row is pulled in via the digit-ratio test so the
// block spans every MRZ line, not just the ones with fillers.
function locateMrzLines(canvas){
  return getOcrWorker().then(function(w){ return w.setParameters({tessedit_pageseg_mode:'6'})
    .then(function(){ return w.recognize(canvas,{},{blocks:true}); })
    .then(function(r){ var L=[];
      (r.data.blocks||[]).forEach(function(b){(b.paragraphs||[]).forEach(function(pp){(pp.lines||[]).forEach(function(ln){
        if(isAnchor(ln.text)||isNumericMrz(ln.text)) L.push({b:ln.bbox}); });});});
      return L; }); });
}
// Returns {data, confidence} or null. OCRs the tight crop two binarized ways and
// votes them; both see the same tight pixels so the name stays consistent.
function locateRecrop(img){
  var sc=Math.min(1,2000/img.width);
  var c=document.createElement('canvas'); c.width=Math.floor(img.width*sc); c.height=Math.floor(img.height*sc);
  c.getContext('2d').drawImage(img,0,0,c.width,c.height);
  return locateMrzLines(c).then(function(L){
    var cl=bottomCluster(L); if(!cl) return null;
    var crop=recropBlock(img,cl,sc);
    var texts=[];
    return ['adaptive','otsu','grey'].reduce(function(ch,mode){
      return ch.then(function(){
        var cc=cloneCanvas(crop); sharpenCanvas(cc); if(mode==='adaptive')binAdaptW(cc); else if(mode==='otsu')binarizeCanvas(cc,'otsu');
        return ocrImage(cc,6).then(function(t){ if(t&&t.trim())texts.push(t); }).catch(function(){});
      });
    },Promise.resolve()).then(function(){ return texts.length?parseConf(texts):null; });
  });
}

// ─── Driver ─────────────────────────────────────────────────────────────────
function loadImage(url){ return new Promise(function(res,rej){ var im=new Image(); im.crossOrigin='anonymous'; im.onload=function(){res(im);}; im.onerror=rej; im.src=url; }); }
function parse(texts){
  return fetch('{{ path('dev_mrz_parse') }}',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({mrz_texts:texts})})
    .then(function(r){ return r.ok?r.json():null; }).catch(function(){return null;});
}
function parseConf(texts){
  return fetch('{{ path('dev_mrz_parse') }}',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({mrz_texts:texts})})
    .then(function(r){ return r.json().then(function(d){ return {confidence:d.confidence||0, data:r.ok?d:null}; }); }).catch(function(){return null;});
}
function norm(v){ return v==null?'':String(v).trim().toUpperCase(); }

async function main(){
  var files=Object.keys(GROUND_TRUTH);
  var only=new URLSearchParams(location.search).get('only');
  if(only){ var set=only.split(','); files=files.filter(function(f){return set.indexOf(f)>=0||set.indexOf(f.replace('.jpg',''))>=0;}); }
  var hits={}, total=0, allOk=0; FIELDS.forEach(function(f){hits[f]=0;});
  for(var i=0;i<files.length;i++){
    var file=files[i], gt=GROUND_TRUTH[file];
    statusEl.textContent='('+(i+1)+'/'+files.length+') '+file+' …';
    var data=null, via='-';
    try{
      var img=await loadImage('{{ path('dev_mrz_corpus_image', {file: 'FILE'}) }}'.replace('FILE',file));
      // Primary: locate-then-recrop. Accept only when checksum-solid (≥30), so a
      // bad block falls through to the proven 3-pass pipeline rather than winning.
      var lr=null; try{ lr=await locateRecrop(img); }catch(e){}
      if(lr&&lr.data&&lr.confidence>=30){ data=lr.data; via='locate'; }
      if(!data){
        var prep=preprocessLoadedImage(img);
        var passes=buildPasses(prep,img), texts=[];
        for(var pi=0;pi<passes.length;pi++){ try{ var t=await passes[pi].run(); if(t&&t.trim())texts.push(t); }catch(e){} }
        data=texts.length?await parse(texts):null; via=data?'3pass':'-';
      }
      window.__MRZ_RAW[file]={via:via,lrConf:lr?lr.confidence:0};
    }catch(e){}
    var row=document.createElement('tr'); var cells='<td>'+file+'</td>'; var rowOk=true;
    FIELDS.forEach(function(f){
      var exp=norm(gt[f]), act=norm(data?data[f]:'');
      var match=exp===act; if(match)hits[f]++; else rowOk=false;
      cells+='<td class="'+(match?'ok':'bad')+'">'+(match?'✓':(act||'—'))+'</td>';
    });
    total++; if(rowOk)allOk++;
    cells+='<td class="'+(rowOk?'ok':'bad')+'">'+(rowOk?'OK':'FAIL')+'</td>';
    row.innerHTML=cells; tbody.appendChild(row);
  }
  var perField={}; FIELDS.forEach(function(f){perField[f]=hits[f]+'/'+total;});
  window.__MRZ_SUMMARY={allCorrect:allOk,total:total,perField:perField};
  window.__MRZ_DONE=true;
  statusEl.textContent='Hotovo.';
  document.getElementById('summary').textContent='VŠE SPRÁVNĚ: '+allOk+' / '+total+'  |  '+FIELDS.map(function(f){return f+' '+perField[f];}).join('  ');
}
main();
</script>
</body>
</html>
