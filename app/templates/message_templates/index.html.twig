{% extends 'settings/base.html.twig' %}

{% block title %}Nastavení — šablony zpráv{% endblock %}

{% block settings_active %}messages{% endblock %}

{% block settings_content %}
    <h2 class="h5 mb-2">Šablony zpráv hostům</h2>
    <p class="text-muted small">
        Texty jednotlivých e-mailů hostům. Společný vzhled (logo, barvy, patička)
        nastavíš v záložce <strong>E-maily</strong>. V textu lze používat proměnné
        jako <code>{{ '{{ guest_first_name }}' }}</code>.
    </p>

    <div class="list-group">
        {% for row in rows %}
            <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-start"
               href="{{ path('message_templates_edit', { kind: row.kind.value }) }}">
                <div class="me-3">
                    <div class="fw-semibold">{{ row.kind.label }}</div>
                    <div class="small text-muted">{{ row.kind.description }}</div>
                    {% if row.kind.isScheduled and row.template.timingSummary %}
                        <div class="small text-muted mt-1">🕑 {{ row.template.timingSummary }}</div>
                    {% endif %}
                </div>
                <span class="badge rounded-pill text-bg-{{ row.template.mode.badge }} flex-shrink-0">
                    {{ row.template.mode.label }}
                </span>
            </a>
        {% endfor %}
    </div>
{% endblock %}
