{% extends 'base.html.twig' %}

{% block title %}Účty — {{ brand_name }}{% endblock %}

{% block body %}
    {% import _self as f %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h4 mb-0">Účty a cashflow</h1>
        <div>
            <a class="btn btn-sm btn-outline-secondary" href="{{ path('account_summary') }}">Měsíční souhrn</a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        {% for card in cards %}
            <div class="col-12 col-md-4">
                <div class="card h-100">
                    <div class="card-body py-2">
                        <div class="d-flex justify-content-between">
                            <a class="text-decoration-none fw-semibold" href="{{ path('account_show', {id: card.account.id}) }}">
                                {{ card.account.name }}
                            </a>
                            <span class="badge text-bg-light">{{ card.account.type.label }}</span>
                        </div>
                        <div class="fs-4 fw-bold {{ card.balance < 0 ? 'text-danger' : '' }}">
                            {{ card.balance|number_format(0, ',', ' ') }} Kč
                        </div>
                        <div class="small text-muted">
                            {% if card.verifiedAt %}ověřeno k {{ card.verifiedAt|date('j. n. Y') }}{% else %}bez uzávěrky{% endif %}
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-muted">Zatím žádné účty.</div>
        {% endfor %}
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-lg-3">
            {{ f.form_card('Nový výdaj', 'account_expense_add', 'account-expense', accounts, categories, 'expense', expenseGroups) }}
        </div>
        <div class="col-12 col-lg-3">
            {{ f.form_card('Ostatní příjem', 'account_income_add', 'account-income', accounts, categories, 'income', expenseGroups) }}
        </div>
        <div class="col-12 col-lg-3">
            {{ f.form_card('Převod mezi účty', 'account_transfer_add', 'account-transfer', accounts, categories, 'transfer', expenseGroups) }}
        </div>
        <div class="col-12 col-lg-3">
            {{ f.form_card('Uzávěrka (reálný stav)', 'account_statement_add', 'account-statement', accounts, categories, 'statement', expenseGroups) }}
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span>Pohyby <span class="small text-muted">({{ total }})</span></span>
            <form method="get" action="{{ path('account_index') }}" class="row row-cols-auto g-1 align-items-end small">
                <div class="col">
                    <select name="account" class="form-select form-select-sm">
                        <option value="">Všechny účty</option>
                        {% for a in accounts %}<option value="{{ a.id }}" {{ filter.account and a.id == filter.account.id ? 'selected' }}>{{ a.name }}</option>{% endfor %}
                    </select>
                </div>
                <div class="col">
                    <select name="type" class="form-select form-select-sm">
                        <option value="">Vše</option>
                        {% for t in entryTypes %}<option value="{{ t.value }}" {{ filter.type and t.value == filter.type.value ? 'selected' }}>{{ t.label }}</option>{% endfor %}
                    </select>
                </div>
                <div class="col"><input type="date" name="from" value="{{ filter.from ? filter.from|date('Y-m-d') }}" class="form-control form-control-sm"></div>
                <div class="col"><input type="date" name="to" value="{{ filter.to ? filter.to|date('Y-m-d') }}" class="form-control form-control-sm"></div>
                <div class="col"><button class="btn btn-sm btn-outline-secondary">Filtrovat</button></div>
                <div class="col"><a class="btn btn-sm btn-outline-primary" href="{{ path('account_export_csv', app.request.query.all|filter((v, k) => k != 'page')) }}">CSV</a></div>
            </form>
        </div>
        <table class="table table-sm table-hover align-middle mb-0 small">
            <thead>
                <tr>
                    <th>Datum</th><th>Typ</th><th>Účet</th><th>Kategorie / cíl</th>
                    <th class="text-end">Částka</th><th>Poznámka</th><th></th>
                </tr>
            </thead>
            <tbody>
            {% for m in recent %}
                <tr>
                    <td>{{ m.occurredOn|date('j. n. Y') }}</td>
                    <td>{{ m.type.label }}</td>
                    <td>{{ m.account.name }}</td>
                    <td>
                        {% if m.type.value == 'transfer' %}→ {{ m.counterAccount ? m.counterAccount.name : '—' }}
                        {% elseif m.category %}
                            {{ m.category.label }}
                            {% if m.category.group.value == 'personal' %}<span class="badge text-bg-secondary">osobní</span>{% endif %}
                        {% endif %}
                    </td>
                    <td class="text-end {{ m.type.value == 'expense' ? 'text-danger' : (m.type.value == 'income' ? 'text-success' : '') }}">
                        {{ m.amountCzk|number_format(0, ',', ' ') }} Kč
                    </td>
                    <td class="text-muted">{{ m.note }}</td>
                    <td class="text-end text-nowrap">
                        <a class="btn btn-sm btn-outline-secondary py-0" href="{{ path('account_entry_edit', {id: m.id}) }}">✎</a>
                        <form method="post" action="{{ path('account_expense_delete', {id: m.id}) }}" class="d-inline" onsubmit="return confirm('Smazat pohyb?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('account-entry-delete-' ~ m.id) }}">
                            <button class="btn btn-sm btn-outline-danger py-0">×</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="7" class="text-muted">Žádné pohyby.</td></tr>
            {% endfor %}
            </tbody>
        </table>
        {% if pages > 1 %}
            <div class="card-footer d-flex justify-content-between align-items-center small">
                <span class="text-muted">Strana {{ page }} / {{ pages }}</span>
                <div class="btn-group">
                    {% if page > 1 %}<a class="btn btn-sm btn-outline-secondary" href="{{ path('account_index', app.request.query.all|merge({page: page - 1})) }}">← Novější</a>{% endif %}
                    {% if page < pages %}<a class="btn btn-sm btn-outline-secondary" href="{{ path('account_index', app.request.query.all|merge({page: page + 1})) }}">Starší →</a>{% endif %}
                </div>
            </div>
        {% endif %}
    </div>

    <div class="card mb-4">
        <div class="card-header">Přijaté příjmy z rezervací <span class="small text-muted">({{ incomeTotal }}, v stavu účtu)</span></div>
        <table class="table table-sm table-hover align-middle mb-0 small">
            <thead>
                <tr><th>Přijato</th><th>Host</th><th>Kanál</th><th>Zdroj</th><th>Účet</th><th class="text-end">Částka</th></tr>
            </thead>
            <tbody>
            {% for i in incomes %}
                <tr>
                    <td>{{ i.receivedOn ? i.receivedOn|date('j. n. Y') : '—' }}</td>
                    <td><a class="text-decoration-none" href="{{ path('reservation_detail', {id: i.reservation.id}) }}">{{ i.reservation.guestName ?? ('#' ~ i.reservation.id) }}</a></td>
                    <td>{{ i.reservation.channel.value }}</td>
                    <td><span class="badge text-bg-success">{{ i.source.label }}</span></td>
                    <td>{{ i.account ? i.account.name : '—' }}</td>
                    <td class="text-end text-success">{{ i.amountCzk|number_format(0, ',', ' ') }} Kč</td>
                </tr>
            {% else %}
                <tr><td colspan="6" class="text-muted">Zatím žádné přijaté příjmy.</td></tr>
            {% endfor %}
            </tbody>
        </table>
        {% if incomePages > 1 %}
            <div class="card-footer d-flex justify-content-between align-items-center small">
                <span class="text-muted">Strana {{ incomePage }} / {{ incomePages }}</span>
                <div class="btn-group">
                    {% if incomePage > 1 %}<a class="btn btn-sm btn-outline-secondary" href="{{ path('account_index', app.request.query.all|merge({rpage: incomePage - 1})) }}">← Novější</a>{% endif %}
                    {% if incomePage < incomePages %}<a class="btn btn-sm btn-outline-secondary" href="{{ path('account_index', app.request.query.all|merge({rpage: incomePage + 1})) }}">Starší →</a>{% endif %}
                </div>
            </div>
        {% endif %}
    </div>

    {% if estimates is not empty %}
    <div class="card mb-4">
        <div class="card-header">Očekávané výplaty <span class="small text-muted">(výhled — mimo stav účtu, dokud nedorazí)</span></div>
        <table class="table table-sm align-middle mb-0 small">
            <thead>
                <tr><th>Pobyt do</th><th>Host</th><th>Kanál</th><th class="text-end">Odhad (net)</th><th></th></tr>
            </thead>
            <tbody>
            {% for i in estimates %}
                <tr>
                    <td>{{ i.receivedOn ? i.receivedOn|date('j. n. Y') : '—' }}</td>
                    <td><a class="text-decoration-none" href="{{ path('reservation_detail', {id: i.reservation.id}) }}">{{ i.reservation.guestName ?? ('#' ~ i.reservation.id) }}</a></td>
                    <td>{{ i.reservation.channel.value }}</td>
                    <td class="text-end text-muted">{{ i.amountCzk|number_format(0, ',', ' ') }} Kč</td>
                    <td class="text-end"><a class="btn btn-sm btn-outline-primary py-0" href="{{ path('reservation_detail', {id: i.reservation.id}) }}">Zadat výplatu</a></td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    {% endif %}

    <div class="card">
        <div class="card-header">Nový účet</div>
        <div class="card-body">
            <form method="post" action="{{ path('account_add') }}" class="row g-2 align-items-end">
                <input type="hidden" name="_token" value="{{ csrf_token('account-new') }}">
                <div class="col-md-4">
                    <label class="form-label small mb-0">Název</label>
                    <input name="name" class="form-control form-control-sm" required>
                </div>
                <div class="col-md-3">
                    <label class="form-label small mb-0">Typ</label>
                    <select name="type" class="form-select form-select-sm">
                        {% for t in accountTypes %}<option value="{{ t.value }}">{{ t.label }}</option>{% endfor %}
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small mb-0">Počáteční stav (Kč)</label>
                    <input name="opening_balance" type="number" step="1" value="0" class="form-control form-control-sm">
                </div>
                <div class="col-md-2">
                    <button class="btn btn-sm btn-primary w-100">Přidat</button>
                </div>
            </form>
        </div>
    </div>

    {% macro form_card(title, route, token, accounts, categories, kind, expenseGroups) %}
        <div class="card h-100">
            <div class="card-header py-1 small">{{ title }}</div>
            <div class="card-body">
                <form method="post" action="{{ path(route) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token(token) }}">
                    <div class="mb-2">
                        <label class="form-label small mb-0">{{ kind == 'transfer' ? 'Z účtu' : 'Účet' }}</label>
                        <select name="account" class="form-select form-select-sm">
                            {% for a in accounts %}<option value="{{ a.id }}">{{ a.name }}</option>{% endfor %}
                        </select>
                    </div>
                    {% if kind == 'transfer' %}
                        <div class="mb-2">
                            <label class="form-label small mb-0">Na účet</label>
                            <select name="counter_account" class="form-select form-select-sm">
                                {% for a in accounts %}<option value="{{ a.id }}">{{ a.name }}</option>{% endfor %}
                            </select>
                        </div>
                    {% endif %}
                    {% if kind == 'expense' %}
                        <div class="mb-2">
                            <label class="form-label small mb-0">Kategorie</label>
                            <select name="category" class="form-select form-select-sm">
                                {% for grp in expenseGroups %}
                                    <optgroup label="{{ grp.label }}">
                                        {% for c in categories|filter(c => c.group.value == grp.value) %}
                                            <option value="{{ c.value }}">{{ c.label }}</option>
                                        {% endfor %}
                                    </optgroup>
                                {% endfor %}
                            </select>
                        </div>
                    {% endif %}
                    <div class="row g-2 mb-2">
                        <div class="col-6">
                            <label class="form-label small mb-0">{{ kind == 'statement' ? 'K datu' : 'Datum' }}</label>
                            <input name="{{ kind == 'statement' ? 'statement_date' : 'occurred_on' }}" type="date" class="form-control form-control-sm">
                        </div>
                        <div class="col-6">
                            <label class="form-label small mb-0">{{ kind == 'statement' ? 'Reálný stav (Kč)' : 'Částka (Kč)' }}</label>
                            <input name="{{ kind == 'statement' ? 'actual_balance' : 'amount' }}" type="number" step="1" class="form-control form-control-sm" required>
                        </div>
                    </div>
                    <div class="mb-2">
                        <input name="note" class="form-control form-control-sm" placeholder="Poznámka">
                    </div>
                    <button class="btn btn-sm btn-primary w-100">Uložit</button>
                </form>
            </div>
        </div>
    {% endmacro %}
{% endblock %}
