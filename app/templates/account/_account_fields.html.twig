{# Pole pro úpravu účtu — sdílí modal (account/show) i samostatná stránka. Očekává: account, accountTypes. #}
<div class="row g-2">
    <div class="col-md-6">
        <label class="form-label small mb-0">Název</label>
        <input name="name" value="{{ account.name }}" class="form-control form-control-sm" required>
    </div>
    <div class="col-md-6">
        <label class="form-label small mb-0">Typ</label>
        <select name="type" class="form-select form-select-sm">
            {% for t in accountTypes %}
                <option value="{{ t.value }}" {{ t.value == account.type.value ? 'selected' }}>{{ t.label }}</option>
            {% endfor %}
        </select>
    </div>
    <div class="col-md-6">
        <label class="form-label small mb-0">Počáteční stav (Kč)</label>
        <input name="opening_balance" type="number" step="1" value="{{ account.openingBalanceCzk }}" class="form-control form-control-sm">
    </div>
    <div class="col-md-6">
        <label class="form-label small mb-0">Počáteční stav k datu</label>
        <input name="opening_date" type="date" value="{{ account.openingDate|date('Y-m-d') }}" class="form-control form-control-sm">
    </div>
    <div class="col-12">
        <label class="form-label small mb-0">Poznámka</label>
        <input name="note" value="{{ account.note }}" class="form-control form-control-sm">
    </div>
    <div class="col-12 form-check ms-2 mt-2">
        <input class="form-check-input" type="checkbox" name="active" value="1" id="active{{ account.id }}" {{ account.active ? 'checked' }}>
        <label class="form-check-label small" for="active{{ account.id }}">Aktivní účet</label>
    </div>
</div>
