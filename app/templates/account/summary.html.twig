{% extends 'base.html.twig' %}

{% block title %}Měsíční souhrn {{ year }} — {{ brand_name }}{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <a href="{{ path('account_index') }}" class="text-decoration-none small">← Účty</a>
            <h1 class="h3 mb-0 mt-1">Měsíční souhrn cashflow {{ year }}</h1>
        </div>
        <div class="btn-group">
            <a class="btn btn-sm btn-outline-secondary" href="{{ path('account_summary', {year: year - 1}) }}">← {{ year - 1 }}</a>
            <a class="btn btn-sm btn-outline-secondary" href="{{ path('account_summary', {year: year + 1}) }}">{{ year + 1 }} →</a>
        </div>
    </div>

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Přijaté platby vs. výdaje po měsících</span>
            <a class="btn btn-sm btn-outline-secondary py-0" href="{{ path('account_export_csv', {from: year ~ '-01-01', to: year ~ '-12-31'}) }}">Export pohybů CSV</a>
        </div>
        <table class="table table-sm align-middle mb-0 small">
            <thead>
                <tr>
                    <th>Měsíc</th>
                    <th class="text-end">Příjem</th>
                    <th class="text-end">Provozní výdaje</th>
                    <th class="text-end">Osobní / finanční</th>
                    <th class="text-end">Čistý tok</th>
                </tr>
            </thead>
            <tbody>
            {% for row in summary.months %}
                {% set empty = row.income == 0 and row.operating == 0 and row.nonOperating == 0 %}
                <tr class="{{ empty ? 'text-muted' : '' }}">
                    <td>{{ months[row.month - 1] }}</td>
                    <td class="text-end text-success">{{ row.income|number_format(0, ',', ' ') }}</td>
                    <td class="text-end {{ row.operating > 0 ? 'text-danger' : '' }}">{{ row.operating|number_format(0, ',', ' ') }}</td>
                    <td class="text-end {{ row.nonOperating > 0 ? 'text-danger' : '' }}">{{ row.nonOperating|number_format(0, ',', ' ') }}</td>
                    <td class="text-end fw-semibold {{ row.net < 0 ? 'text-danger' : '' }}">{{ row.net|number_format(0, ',', ' ') }}</td>
                </tr>
            {% endfor %}
            </tbody>
            <tfoot class="table-group-divider">
                <tr class="fw-bold">
                    <td>Celkem {{ year }}</td>
                    <td class="text-end text-success">{{ summary.totals.income|number_format(0, ',', ' ') }}</td>
                    <td class="text-end">{{ summary.totals.operating|number_format(0, ',', ' ') }}</td>
                    <td class="text-end">{{ summary.totals.nonOperating|number_format(0, ',', ' ') }}</td>
                    <td class="text-end {{ summary.totals.net < 0 ? 'text-danger' : '' }}">{{ summary.totals.net|number_format(0, ',', ' ') }} Kč</td>
                </tr>
            </tfoot>
        </table>
    </div>
    <p class="small text-muted mt-2">
        Příjem = reálně přijaté platby z rezervací (záloha i doplatek v měsíci svého přijetí).
        Převody mezi vlastními účty a korekce z uzávěrek se nezapočítávají.
    </p>
{% endblock %}
