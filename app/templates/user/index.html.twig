{% extends 'settings/base.html.twig' %}

{% block title %}Uživatelé — {{ brand_name }}{% endblock %}

{% block settings_active %}users{% endblock %}

{% block settings_content %}
<div class="d-flex align-items-center justify-content-between mb-3">
    <h2 class="h5 mb-0">Uživatelé</h2>
    <button class="btn btn-primary btn-sm" type="button" data-bs-toggle="modal" data-bs-target="#modalNewUser">+ Přidat uživatele</button>
</div>

<p class="text-muted small">
    Každý uživatel má jednu <strong>roli</strong>, která určuje rozsah přístupu:
    <strong>Admin</strong> vše včetně nastavení a uživatelů, <strong>Správce</strong>
    provoz i finance, <strong>Uklízečka</strong> jen úklid.
</p>

<div class="modal fade" id="modalNewUser" tabindex="-1" aria-labelledby="modalNewUserLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title h6 mb-0" id="modalNewUserLabel">Nový uživatel</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Zavřít"></button>
            </div>
            <form method="post" action="{{ path('user_create') }}">
                <div class="modal-body">
                    <input type="hidden" name="_token" value="{{ csrf_token('user-create') }}">
                    <div class="mb-3">
                        <label for="newEmail" class="form-label">E-mail</label>
                        <input type="email" name="email" id="newEmail" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label for="newPassword" class="form-label">Heslo</label>
                        <input type="password" name="password" id="newPassword" class="form-control" required minlength="8" autocomplete="new-password">
                    </div>
                    <div class="mb-0">
                        <label for="newRole" class="form-label">Role</label>
                        <select name="role" id="newRole" class="form-select">
                            {% for role in roles %}
                                <option value="{{ role.value }}" {{ role.value == 'ROLE_USER' ? 'selected' }}>{{ role.label }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Zrušit</button>
                    <button type="submit" class="btn btn-primary">Založit</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th scope="col">Uživatel</th>
                    <th scope="col">Role</th>
                    <th scope="col" class="text-center">Aktivní</th>
                    <th scope="col" class="text-end">Akce</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                    {% set fid = 'access-' ~ user.id %}
                    <tr>
                        <td>
                            <div>{{ user.email }}</div>
                            <div class="small text-muted">od {{ user.createdAt|date('j. n. Y') }}</div>
                            <form id="{{ fid }}" method="post" action="{{ path('user_update', {id: user.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('user-update-' ~ user.id) }}">
                            </form>
                        </td>
                        <td>
                            <select name="role" form="{{ fid }}" class="form-select form-select-sm">
                                {% for role in roles %}
                                    <option value="{{ role.value }}" {{ role == user.role ? 'selected' }}>{{ role.label }}</option>
                                {% endfor %}
                            </select>
                        </td>
                        <td class="text-center">
                            <input type="checkbox" name="active" value="1" form="{{ fid }}"
                                   class="form-check-input" aria-label="Aktivní" {{ user.active ? 'checked' }}>
                        </td>
                        <td class="text-end">
                            <div class="d-flex gap-2 justify-content-end align-items-center">
                                <button type="submit" form="{{ fid }}" class="btn btn-sm btn-outline-primary">Uložit</button>
                                <form method="post" action="{{ path('user_reset_password', {id: user.id}) }}" class="d-flex gap-1">
                                    <input type="password" name="password" class="form-control form-control-sm" style="width:9rem"
                                           placeholder="Nové heslo" minlength="8" autocomplete="new-password" required>
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">Heslo</button>
                                    <input type="hidden" name="_token" value="{{ csrf_token('user-password-' ~ user.id) }}">
                                </form>
                                <form method="post" action="{{ path('user_delete', {id: user.id}) }}"
                                      onsubmit="return confirm('Smazat uživatele {{ user.email }}?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Smazat</button>
                                    <input type="hidden" name="_token" value="{{ csrf_token('user-delete-' ~ user.id) }}">
                                </form>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
