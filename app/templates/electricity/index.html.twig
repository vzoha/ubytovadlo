{% extends 'base.html.twig' %}

{% block title %}Elektřina{% endblock %}

{% block body %}
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <h1 class="h3 mb-0">Elektřina — odečty</h1>
        <div class="d-flex gap-2">
            <button class="btn btn-primary btn-sm" type="button" data-bs-toggle="modal" data-bs-target="#modalReading">+ Nový odečet</button>
            <form method="post" action="{{ path('electricity_rebalance') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('electricity-rebalance') }}">
                <button class="btn btn-outline-secondary btn-sm">Přepočítat alokaci</button>
            </form>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">Tarify</div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <thead class="small text-muted">
                        <tr><th>Platný od</th><th class="text-end">VT Kč/kWh</th><th class="text-end">NT Kč/kWh</th></tr>
                        </thead>
                        <tbody>
                        {% for t in tariffs %}
                            <tr>
                                <td>{{ t.validFrom|date('d. m. Y') }}</td>
                                <td class="text-end">{{ t.vtRate|number_format(2, ',', ' ') }}</td>
                                <td class="text-end">{{ t.ntRate|number_format(2, ',', ' ') }}</td>
                            </tr>
                        {% else %}
                            <tr><td colspan="3" class="text-muted small">Žádné tarify zatím nejsou.</td></tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">Historie odečtů ({{ readings|length }})</div>
                <div class="card-body p-0">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="small text-muted">
                        <tr>
                            <th>Datum</th>
                            <th class="text-end">VT</th>
                            <th class="text-end">NT</th>
                            <th>Poznámka</th>
                            <th></th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for r in readings %}
                            <tr>
                                <td>{{ r.readAt|date('d. m. Y') }}</td>
                                <td class="text-end">{{ r.vtMeter|number_format(0, ',', ' ') }}</td>
                                <td class="text-end">{{ r.ntMeter|number_format(0, ',', ' ') }}</td>
                                <td class="small text-muted">{{ r.note ?? '' }}</td>
                                <td class="text-end">
                                    <form method="post" action="{{ path('electricity_delete', {id: r.id}) }}"
                                          onsubmit="return confirm('Smazat odečet z {{ r.readAt|date('d. m. Y') }}?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('electricity-delete-' ~ r.id) }}">
                                        <button class="btn btn-sm btn-outline-danger py-0" title="Smazat odečet">×</button>
                                    </form>
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="5" class="text-muted small p-3">Žádné odečty zatím nejsou.</td></tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalReading" tabindex="-1" aria-labelledby="modalReadingLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title h6 mb-0" id="modalReadingLabel">Nový odečet</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Zavřít"></button>
                </div>
                <form method="post" action="{{ path('electricity_create') }}">
                    <div class="modal-body">
                        <input type="hidden" name="_token" value="{{ csrf_token('electricity-reading') }}">
                        <div class="mb-2">
                            <label class="form-label small mb-1">Datum odečtu</label>
                            <input type="date" name="read_at" required class="form-control form-control-sm" value="{{ 'now'|date('Y-m-d') }}">
                        </div>
                        <div class="row g-2">
                            <div class="col">
                                <label class="form-label small mb-1">VT stav (kWh)</label>
                                <input type="number" name="vt_meter" required min="0" class="form-control form-control-sm">
                            </div>
                            <div class="col">
                                <label class="form-label small mb-1">NT stav (kWh)</label>
                                <input type="number" name="nt_meter" required min="0" class="form-control form-control-sm">
                            </div>
                        </div>
                        <div class="mt-2">
                            <label class="form-label small mb-1">Poznámka</label>
                            <input type="text" name="note" class="form-control form-control-sm" placeholder="např. po pobytu Novák">
                        </div>
                        <p class="text-muted small mb-0 mt-2">
                            Po uložení se automaticky přepočítá alokace spotřeby na rezervace v intervalu.
                        </p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Zrušit</button>
                        <button class="btn btn-sm btn-primary">Uložit odečet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
