{% extends 'base.html.twig' %}

{% block title %}Úprava faktury {{ invoice.number }}{% endblock %}

{% block body %}
    <h1 class="h3 mb-3">Úprava faktury {{ invoice.number }}</h1>
    <p class="text-muted">
        Rezervace
        <a href="{{ path('reservation_detail', {id: reservation.id}) }}">#{{ reservation.id }} {{ reservation.guestName }}</a>
        · {{ invoice.type.label }}
        · {{ invoice.totalAmount|number_format(2, ',', ' ') }} {{ invoice.currency == 'CZK' ? 'Kč' : invoice.currency }}
    </p>

    <form method="post" class="card card-body" style="max-width: 480px;">
        <input type="hidden" name="_token" value="{{ csrf_token('invoice-edit-' ~ invoice.id) }}">

        <div class="mb-3">
            <label class="form-label">Datum vystavení</label>
            <input type="date" name="issued_at" class="form-control" required
                   value="{{ invoice.issuedAt|date('Y-m-d') }}">
            <div class="form-text">Musí zůstat v roce {{ invoice.seriesYear }} kvůli číselné řadě.</div>
        </div>

        <div class="mb-3">
            <label class="form-label">Datum splatnosti</label>
            <input type="date" name="due_at" class="form-control" required
                   value="{{ invoice.dueAt|date('Y-m-d') }}">
        </div>

        <div class="mb-3">
            <label class="form-label">Způsob platby</label>
            <select name="payment_method" class="form-select">
                {% set methods = ['převodem', 'hotově'] %}
                {% if invoice.paymentMethod not in methods %}
                    <option value="{{ invoice.paymentMethod }}" selected>{{ invoice.paymentMethod }}</option>
                {% endif %}
                {% for method in methods %}
                    <option value="{{ method }}" {{ invoice.paymentMethod == method ? 'selected' }}>{{ method }}</option>
                {% endfor %}
            </select>
            <div class="form-text">Hotovost odstraní z faktury číslo účtu i QR kód.</div>
        </div>

        <div class="mb-3">
            <label class="form-label">Datum platby</label>
            <input type="date" name="paid_at" class="form-control"
                   value="{{ invoice.paidAt ? invoice.paidAt|date('Y-m-d') : '' }}">
            <div class="form-text">Prázdné = nezaplaceno.</div>
        </div>

        {% if invoice.originalCurrency %}
            <div class="alert alert-warning small mb-3">
                Kurz ČNB {{ invoice.exchangeRate }} ({{ invoice.exchangeRateDate|date('d. m. Y') }})
                se při úpravě data <strong>nepřepočítává</strong>. Pokud jde o věcnou opravu kurzu,
                fakturu zruš a vystav znovu.
            </div>
        {% endif %}

        <div class="d-flex gap-2">
            <button class="btn btn-primary">Uložit</button>
            <a href="{{ path('reservation_detail', {id: reservation.id}) }}" class="btn btn-link">Zpět</a>
        </div>
    </form>
{% endblock %}
