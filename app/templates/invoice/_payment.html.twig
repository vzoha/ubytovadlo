<div class="payment-wrap">
    <table class="payment"><tr>
        <td class="pay-left">
            <table class="pay-inner"><tr>
                <td class="nw pay-keys-left">
                    <span class="pay-key pay-strong">Variabilní symbol</span><br>
                    <span class="pay-key">Způsob platby</span>
                    {% if invoice.bankAccount %}<br><span class="pay-key pay-strong">Číslo účtu</span>{% endif %}
                </td>
                <td class="nw">
                    <span class="pay-val pay-strong">{{ invoice.displayVariableSymbol }}</span><br>
                    <span class="pay-val">{{ invoice.paymentMethod }}</span>
                    {% if invoice.bankAccount %}<br><span class="pay-val pay-strong">{{ invoice.bankAccount }}</span>{% endif %}
                </td>
            </tr></table>
        </td>
        <td class="pay-right">
            <table class="pay-inner pay-inner-right"><tr>
                <td class="nw pay-keys-right">
                    <span class="pay-key">Datum vystavení</span><br>
                    <span class="pay-key pay-strong">Datum splatnosti</span>
                </td>
                <td class="nw pay-vals-right">
                    <span class="pay-val">{{ invoice.issuedAt|date('j.n.Y') }}</span><br>
                    <span class="pay-val pay-strong">{{ invoice.dueAt|date('j.n.Y') }}</span>
                </td>
                <td class="pay-qr">
                    {% if invoice.qrPayload %}
                        <barcode code="{{ invoice.qrPayload }}" type="QR" size="1.3" error="M" />
                    {% endif %}
                </td>
            </tr></table>
        </td>
    </tr></table>
</div>
