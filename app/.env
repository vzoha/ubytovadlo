# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=changeme-set-in-env-local
APP_SHARE_DIR=var/share
# Master klic pro sifrovani creds ulozenych v DB (tabulka credential), base64 32 B.
# Vygeneruj: php -r "echo base64_encode(random_bytes(32)).PHP_EOL;" a uloz do .env.local.
# Prazdne = creds se ctou jen z .env (DB store neaktivni).
APP_CREDENTIALS_KEY=''
# Nazev ubytovani zobrazovany v UI, titulcich a na fakture. Realny nazev patri do .env.local.
APP_BRAND_NAME=Ubytovadlo
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=8.0.32&charset=utf8mb4"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
DATABASE_URL="mysql://ubytovadlo:ubytovadlo@db:3306/ubytovadlo?serverVersion=8.4&charset=utf8mb4"

###> imap ###
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_ENCRYPTION=ssl
IMAP_USERNAME=automatizace@example.com
IMAP_PASSWORD=changeme-set-in-env-local
IMAP_FOLDER=INBOX
###< imap ###

###> motopress ###
MOTOPRESS_BASE_URL=https://example.com
MOTOPRESS_CONSUMER_KEY=changeme-set-in-env-local
MOTOPRESS_CONSUMER_SECRET=changeme-set-in-env-local
# carka-oddelene IDs MotoPress sluzeb, ktere znamenaji "host se psem"
MOTOPRESS_PET_SERVICE_IDS=925
# carka-oddelene IDs MotoPress sluzeb, ktere znamenaji "host potrebuje detskou postylku"
MOTOPRESS_BABY_COT_SERVICE_IDS=866
# 1 = po sparovani prichozi platby oznacit platbu v MotoPressu jako "completed"
# (vyzaduje API klic s pravem Write). Vychozi 0 = vypnuto (instance bez MotoPressu).
MOTOPRESS_PUSH_PAYMENTS=0
###< motopress ###

###> faktura ###
# Profil dodavatele — REALNE hodnoty patri do .env.local (nikdy necommitovat: DIC=rodne cislo, telefon, ucet)
INVOICE_ISSUER_NAME="Jmeno Prijmeni"
INVOICE_ISSUER_STREET="Ulice 1"
INVOICE_ISSUER_CITY="Mesto"
INVOICE_ISSUER_ZIP="00000"
INVOICE_ISSUER_COUNTRY="Česká republika"
INVOICE_ISSUER_ICO="00000000"
INVOICE_ISSUER_DIC="CZ0000000000"
INVOICE_ISSUER_PHONE="+420 000 000 000"
INVOICE_ISSUER_EMAIL="info@example.com"
INVOICE_ISSUER_WEB="https://example.com"
INVOICE_BANK_ACCOUNT="000000000/0000"
INVOICE_BANK_IBAN="CZ0000000000000000000000"

# Navazani ciselne rady faktur (rok -> prvni poradove cislo). Prazdna mapa = kazdy
# rok zacina od 1. Nastavuje se v UI (/nastaveni/fakturace); tohle je jen fallback.
INVOICE_SERIES_STARTS='{}'

# Vyse zalohy v CZK
INVOICE_DEPOSIT_AMOUNT=1000
###< faktura ###
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
# SMTP se primarne nastavuje v UI (/nastaveni/pripojeni, sifrovane v DB) — tohle je
# jen fallback, kdyz v DB SMTP neni. Vychozi null:// nic neodesila (bezpecne pro repo
# i vyvoj). Realne SMTP pripadne do .env.local, napr.
# MAILER_DSN=smtp://user:pass@mail.hukot.net:465?encryption=ssl
MAILER_DSN=null://null
###< symfony/mailer ###
