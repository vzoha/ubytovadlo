# NEpatří ani sem — ta žijí jen v app/.env.local (viz app/.gitignore).

# WordPress instalace — udržovaná zvlášť, není součástí tohoto repa
/www/

# Vzorky dat a backfilly (e-maily, CSV evidence, jednorázové SQL) — mohou
# obsahovat reálná PII, do veřejného repa nepatří
/sources/

# Privátní overlay a interní dokumentace — identita instance, runbooky, plány
/CLAUDE.local.md          # kdo/co je tahle instance (doména, schránka, účty)
/docs/private/            # interní runbooky a plány funkcí

# Editor / OS junk
.idea/
.vscode/
.DS_Store
*.swp

# Stažený obsah skillů (jako vendor/) — verze drží skills-lock.json
